---
import Base from '../layouts/Base.astro';
import { getContent } from '../lib/content.js';

const { notfound } = await getContent('notfound');
---
<Base title="Page Not Found | Sabdia Constructions" description="The page you're looking for could not be found.">
  <section style="min-height:100svh;display:flex;align-items:center;background:var(--dark);padding:clamp(120px,16vw,180px) clamp(22px,5vw,80px) clamp(80px,10vw,120px)">
    <div class="inner" style="text-align:center;width:100%">
      <div style="font-family:var(--font-d);font-size:clamp(120px,24vw,280px);font-weight:300;font-style:italic;line-height:1;color:rgba(158,139,106,.14);user-select:none">404</div>
      <h1 style="font-family:var(--font-d);font-size:clamp(36px,6vw,72px);font-weight:300;letter-spacing:-.02em;color:var(--white);margin-top:-.6em" set:html={notfound.titleHtml} />
      <p style="font-size:13px;font-weight:300;color:rgba(253,252,248,.45);max-width:420px;margin:26px auto 40px;line-height:1.85">{notfound.text}</p>
      <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
        <a href={notfound.primaryCta.href} class="btn-p">{notfound.primaryCta.label} &rarr;</a>
        <a href={notfound.secondaryCta.href} class="btn-g btn-g-light">{notfound.secondaryCta.label}</a>
      </div>
    </div>
  </section>
</Base>
