---
import Base from '../../layouts/Base.astro';
import CustomSections from '../../components/CustomSections.astro';
import PropertyCard from '../../components/PropertyCard.astro';
import PropertyViewer from '../../components/PropertyViewer.astro';
import FilmBand from '../../components/FilmBand.astro';
import SeriesStrip from '../../components/SeriesStrip.astro';
import WalkthroughCinema from '../../components/WalkthroughCinema.astro';
import { imgVariant, landLabel } from '../../lib/images.js';
import { getProperties, getProperty } from '../../lib/db.js';
import { getContent } from '../../lib/content.js';

const entry = await getProperty(Astro.params.slug);
if (!entry) {
  return new Response('Not found', { status: 404 });
}
const d = entry.data;
const sold = d.status === 'sold';
const statusLabel = sold ? 'Sold Prior to Completion' : 'For Sale';

const paragraphs = entry.body.trim().split(/\n\s*\n/).map((p) => p.trim()).filter(Boolean);

const [allProps, { films, series, settings, property_page: pp }] = await Promise.all([
  getProperties(),
  getContent('films', 'series', 'settings', 'property_page'),
]);
/* Shared framing copy, editable in the admin (Site Content → Property
   pages); {name} tokens become this residence's name. */
const N = (s) => (s ?? '').replaceAll('{name}', d.name);
const film = films?.byProperty?.[entry.id];
const seriesPosts = series?.byProject?.[entry.id] ?? [];
const related = allProps
  .filter((p) => p.data.status === 'for-sale' && p.id !== entry.id)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

/* Cinematic walkthroughs — curated chapters of studio-rendered clips,
   web-encoded and hosted in Supabase storage (media/walkthrough/<slug>/).
   Add an entry per property as clip sets arrive; pages without one
   simply skip the section. */
const WT = 'https://fvczsjcrvwzqtcbforgo.supabase.co/storage/v1/object/public/media/walkthrough';
const walkthroughs = {
  qasr: [
    { label: 'Arrival', src: `${WT}/qasr/web-clip14.mp4` },
    { label: 'Motor Court', src: `${WT}/qasr/web-clip18.mp4` },
    { label: 'Entry Void', src: `${WT}/qasr/web-clip19.mp4` },
    { label: 'Lounge', src: `${WT}/qasr/web-clip22_3.mp4` },
    { label: 'Fireside', src: `${WT}/qasr/web-clip25_1.mp4` },
    { label: 'The Bar', src: `${WT}/qasr/web-clip21.mp4` },
    { label: 'Dining', src: `${WT}/qasr/web-clip27_1.mp4` },
    { label: 'Pool Courtyard', src: `${WT}/qasr/web-clip16.mp4` },
    { label: 'Dusk', src: `${WT}/qasr/web-clip17_1.mp4` },
  ],
};
const walkthrough = walkthroughs[entry.id];

/* Gallery — entries arrive deduped from the data layer (see db.js);
   here each image is re-cropped for the layout slot it will occupy. */
const galleryUnique = d.gallery ?? [];
const gcount = Math.min(galleryUnique.length, 6);
/* slot letter per index: a = lead portrait, b/c = right column, d/e/f = bottom rows */
const slotFor = (i) => (i < 3 ? 'abc'[i] : 'def'[(i - 3) % 3]);
const slotCrop = (i) => {
  if (gcount === 1) return { w: 1800, h: 780 };
  if (gcount === 2) return { w: 1200, h: 900 };
  const s = slotFor(i);
  if (s === 'a') return { w: 1200, h: 1500 };
  if (s === 'b' || s === 'c') return { w: 1100, h: 900 };
  if (gcount === 4 && i === 3) return { w: 1800, h: 800 };
  if (gcount === 5) return { w: 1200, h: 700 };
  return { w: 900, h: 560 };
};
const gallery = galleryUnique.map((g, i) => {
  const { w, h } = slotCrop(i);
  return {
    ...g,
    slot: slotFor(i),
    src: imgVariant(g.src, { w, h, q: 88 }),
    full: imgVariant(g.src, { w: Math.round(w * 1.5), h: Math.round(h * 1.5), q: 85 }),
  };
});

const heroImg = imgVariant(d.image, { w: 1920, h: 1080, focus: d.focus, q: sold ? 85 : 90 });
const ogImg = imgVariant(d.image, { w: 1200, h: 630, focus: d.focus });

const base = (Astro.site ?? new URL('https://www.sabdiaconstructions.com.au')).origin;
const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${base}/` },
    { '@type': 'ListItem', position: 2, name: 'Properties', item: `${base}/properties/` },
    { '@type': 'ListItem', position: 3, name: d.name, item: `${base}/properties/${entry.id}/` },
  ],
});
const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SingleFamilyResidence',
  name: d.name,
  description: d.seoDescription,
  numberOfRooms: d.beds,
  numberOfBathroomsTotal: d.baths,
  numberOfBedrooms: d.beds,
  floorSize: { '@type': 'QuantitativeValue', value: d.land, unitCode: 'MTK' },
  address: { '@type': 'PostalAddress', addressLocality: d.suburb, addressRegion: 'QLD', addressCountry: 'AU' },
  image: ogImg,
  brand: { '@type': 'Brand', name: 'Sabdia Constructions' },
});
---
<Base
  title={`${d.name} | Sabdia Constructions`}
  description={d.seoDescription}
  ogTitle={`${d.name} — ${d.suburb} · Sabdia Constructions`}
  ogDescription={d.seoDescription}
  ogImage={ogImg}
>
  <script type="application/ld+json" slot="head" is:inline set:html={jsonLd} />
  <script type="application/ld+json" slot="head" is:inline set:html={breadcrumbLd} />

  <!-- PROP HERO -->
  <section class="prop-hero">
    <img src={heroImg} alt={d.name} loading="eager" style={`position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:${sold ? 'brightness(.72) saturate(.9)' : 'brightness(.78) saturate(.96)'}`}>
    <div class="prop-hero-ov"></div>
    <div class="prop-hero-content inner">
      <div class="prop-status" style={sold ? 'margin-bottom:14px' : undefined}>
        <div class={`prop-status-dot ${sold ? 'sold' : 'active'}`}></div>
        {/* Only the colour is set inline — size, weight, tracking and case
            all inherit from .prop-status so the label can be sized in one
            place. An inline font-size here silently outranks the stylesheet. */}
        <span style="color:rgba(253,251,246,.88)">{statusLabel}</span>
      </div>
      <div class="prop-name">{d.name}</div>
      <div class="prop-loc">{d.suburb}, {d.state}</div>
    </div>
  </section>

  {sold && (
    <div style="background:var(--bg2);border-bottom:1px solid var(--border);padding:22px clamp(22px,5vw,80px)">
      <div class="inner" style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
        <div style="padding:7px 16px;background:rgba(180,155,90,.14);border:1px solid rgba(180,155,90,.4);font-size:10px;font-weight:500;letter-spacing:.24em;text-transform:uppercase;color:var(--ink)">{pp.soldBadge}</div>
        <span style="font-size:13.5px;font-weight:400;color:var(--ink3)">{pp.soldNotice}</span>
        <a href="/properties/" class="btn-g btn-g-gold" style="margin-left:auto;padding:9px 20px;font-size:10px">View Available &rarr;</a>
      </div>
    </div>
  )}

  <!-- SPECS BAR -->
  <div class="prop-specs-bar">
    <div class="prop-specs-inner">
      <div class="prop-spec-item">
        <div class="prop-spec-l">Location</div>
        <div class="prop-spec-v" style="font-size:16px">{d.suburb}</div>
      </div>
      <div class="prop-spec-item">
        <div class="prop-spec-l">Bedrooms</div>
        <div class="prop-spec-v">{d.beds}</div>
      </div>
      <div class="prop-spec-item">
        <div class="prop-spec-l">Bathrooms</div>
        <div class="prop-spec-v">{d.baths}</div>
      </div>
      <div class="prop-spec-item">
        <div class="prop-spec-l">Garages</div>
        <div class="prop-spec-v">{d.cars}</div>
      </div>
      <div class="prop-spec-item">
        <div class="prop-spec-l">Land Size</div>
        <div class="prop-spec-v">{d.land}<em>m²{d.landOver ? '+' : ''}</em></div>
      </div>
      <div class="prop-spec-item">
        <div class="prop-spec-l">Status</div>
        <div class="prop-spec-v" style={`font-size:16px;color:${sold ? 'var(--taupe-d)' : 'var(--ink)'}`}>{sold ? 'Sold' : 'For Sale'}</div>
      </div>
    </div>
  </div>

  <CustomSections page="property-detail" position="top" />

  <!-- BODY -->
  <div class="prop-body">
    <div class="prop-layout inner">
      <div class="prop-desc">
        <div class="slabel prop-desc-slabel reveal">About {d.name}</div>
        <h1 class="prop-body-h reveal d1" set:html={d.headline} />
        {paragraphs.map((p) => <p class="prop-body-p reveal d2">{p}</p>)}

        <div class="prop-features reveal d3">
          <div class="prop-features-h">Key Features</div>
          <div class="prop-feat-grid">
            {d.features.map((f) => <div class="prop-feat">{f}</div>)}
          </div>
        </div>
      </div>

      <div class="reveal d2">
        <div class="prop-enquire">
          <div class="prop-enquire-h">{d.enquiryHeading}</div>
          <p style="font-size:13px;font-weight:300;color:var(--ink3);line-height:1.75;margin-bottom:24px">{d.enquiryText}</p>
          <form class="cform" id="cform" name="property-enquiry" method="POST" action="/api/contact">
            <input type="hidden" name="form-name" value="property-enquiry">
            <input type="hidden" name="property" value={d.name}>
            <p class="hidden" style="display:none" aria-hidden="true"><label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off"></label></p>
            <div class="frow">
              <div class="fg"><label class="fl" for="pe-first">First Name*</label><input type="text" id="pe-first" name="first-name" class="fi" placeholder="First name" autocomplete="given-name" required></div>
              <div class="fg"><label class="fl" for="pe-last">Last Name*</label><input type="text" id="pe-last" name="last-name" class="fi" placeholder="Last name" autocomplete="family-name" required></div>
            </div>
            <div class="fg"><label class="fl" for="pe-email">Email*</label><input type="email" id="pe-email" name="email" class="fi" placeholder="Email address" autocomplete="email" required></div>
            <div class="fg"><label class="fl" for="pe-phone">Phone</label><input type="tel" id="pe-phone" name="phone" class="fi" placeholder="Phone number" autocomplete="tel"></div>
            {!sold && (
              <div class="fg">
                <label class="fl">Enquiry Type</label>
                <select class="fsel" name="enquiry-type">
                  <option>Register Interest</option>
                  <option>Arrange Private Inspection</option>
                  <option>Request Price Guide</option>
                  <option>General Enquiry</option>
                </select>
              </div>
            )}
            <div class="fg"><label class="fl">Message</label><textarea class="fta" name="message" placeholder="Tell us about your requirements or any questions you have…"></textarea></div>
            <p class="form-note">By submitting this form you agree to our privacy policy. Your details will not be shared with third parties.</p>
            <button type="submit" class="fsub" id="fsub">{d.enquiryButton} &rarr;</button>
            <p class="sr-status" role="status" aria-live="polite" data-form-status></p>
          </form>
        </div>
        <div style="margin-top:16px;display:flex;flex-direction:column;gap:10px">
          {d.brochureUrl && <a href={d.brochureUrl} target="_blank" rel="noopener" class="btn-g btn-g-gold" style="justify-content:center" download>Download Brochure &darr;</a>}
          {sold && <a href="/properties/" class="btn-p" style="justify-content:center">View Current Properties</a>}
          <a href="/contact/" class={`btn-g ${sold ? '' : 'btn-g-gold'}`} style="justify-content:center">General Enquiry</a>
        </div>
      </div>
    </div>
  </div>

  <!-- GALLERY -->
  {gallery.length > 0 && (
    <div class="prop-gallery inner">
      <div class="slabel reveal">{pp.galleryLabel}</div>
      <h2 class="prop-gallery-h reveal d1" set:html={N(pp.galleryHeadingHtml)} />
      <div class={`prop-gallery-grid gn-${gcount}`} id="galleryGrid">
        {gallery.map((g, i) => (
          <div class={`gallery-item gallery-${g.slot} reveal-wipe ${['', 'd1', 'd2', 'd1', 'd2', 'd3'][i] ?? 'd3'}`} data-lb-item data-src={g.full} data-alt={g.alt} role="button" tabindex="0" aria-label={`View photo: ${g.alt}`}>
            <img class="gallery-img" src={g.src} alt={g.alt} loading="lazy">
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- LIGHTBOX -->
  <div class="lb" id="lb" role="dialog" aria-modal="true" aria-label="Photo viewer">
    <img id="lbImg" src="" alt="">
    <button class="lb-btn lb-prev" id="lbPrev" aria-label="Previous photo">&larr;</button>
    <button class="lb-btn lb-next" id="lbNext" aria-label="Next photo">&rarr;</button>
    <button class="lb-close" id="lbClose" aria-label="Close">&#10005;</button>
    <div class="lb-meta"><span class="lb-cap" id="lbCap"></span><span id="lbCount"></span></div>
  </div>

  <!-- FILM -->
  {film?.video && (
    <FilmBand
      id="film"
      label={films.sectionLabel || 'The Film'}
      headingHtml={`Experience <em>${d.name}</em>.`}
      text={`Step inside ${d.name} — a cinematic walkthrough of the residence, its materials, and its light.`}
      video={film.video}
      poster={film.poster}
      captionLeft={`${d.name} — On Film`}
      captionRight={`${d.suburb}, ${d.state}`}
    />
  )}

  <!-- 3D VIEWER -->
  <PropertyViewer property={entry} />

  <!-- CINEMATIC WALKTHROUGH -->
  {walkthrough && <WalkthroughCinema name={d.name} chapters={walkthrough} />}

  <!-- THE SERIES -->
  <SeriesStrip items={seriesPosts} name={d.name} label={series?.label} handle={series?.handle} instagramUrl={settings.socials.instagram.url} />

  <!-- CLOSING ENQUIRY -->
  {!sold && (
    <section class="prop-cta">
      <div class="inner prop-cta-inner">
        <div class="slabel reveal" style="justify-content:center">{pp.cta.label}</div>
        <h2 class="prop-cta-h reveal d1" set:html={N(pp.cta.headingHtml)} />
        <p class="prop-cta-p reveal d2">{N(pp.cta.text)}</p>
        <a href="#cform" class="btn-p reveal d3">{N(pp.cta.button)} &rarr;</a>
      </div>
    </section>
  )}

  <script is:inline>
  /* Keyboard control lives on the document, so it is registered once and
     talks to the current page through lbApi — which astro:page-load
     rebuilds. Closing over `items`/`idx` directly would pin the first
     property page's DOM in memory and stack a handler per navigation. */
  var lbApi = null;
  document.addEventListener('keydown', function (e) {
    if (!lbApi || !lbApi.isOpen()) return;
    if (e.key === 'Escape') lbApi.close();
    if (e.key === 'ArrowLeft') lbApi.prev();
    if (e.key === 'ArrowRight') lbApi.next();
  });

  document.addEventListener('astro:page-load', function () {
    lbApi = null;
    var items = [].slice.call(document.querySelectorAll('[data-lb-item]'));
    if (!items.length) return;
    var lb = document.getElementById('lb');
    var img = document.getElementById('lbImg');
    var cap = document.getElementById('lbCap');
    var count = document.getElementById('lbCount');
    var idx = 0;

    function show(i) {
      idx = (i + items.length) % items.length;
      img.src = items[idx].dataset.src;
      img.alt = items[idx].dataset.alt || '';
      cap.textContent = items[idx].dataset.alt || '';
      count.textContent = (idx + 1) + ' / ' + items.length;
    }
    function open(i) { show(i); lb.classList.add('open'); document.body.style.overflow = 'hidden'; }
    function close() { lb.classList.remove('open'); document.body.style.overflow = ''; }

    items.forEach(function (el, i) {
      el.addEventListener('click', function () { open(i); });
      el.addEventListener('keydown', function (e) { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open(i); } });
    });
    document.getElementById('lbPrev').addEventListener('click', function () { show(idx - 1); });
    document.getElementById('lbNext').addEventListener('click', function () { show(idx + 1); });
    document.getElementById('lbClose').addEventListener('click', close);
    lb.addEventListener('click', function (e) { if (e.target === lb) close(); });

    lbApi = {
      isOpen: function () { return lb.classList.contains('open'); },
      close: close,
      prev: function () { show(idx - 1); },
      next: function () { show(idx + 1); }
    };
  });
  </script>

  <!-- RELATED -->
  <div class="prop-related inner">
    <h2 class="prop-related-h reveal" set:html={sold ? pp.relatedHeadingSoldHtml : pp.relatedHeadingHtml} />
    <div class="prop-related-grid">
      {related.map((p, i) => (
        <PropertyCard
          entry={p}
          class={`reveal ${['', 'd1', 'd2'][i] ?? ''}`}
          style="aspect-ratio:4/3"
          imgW={600}
          imgH={400}
          specs={[`${p.data.beds} Bed`, `${p.data.baths} Bath`, `${p.data.cars} Car`]}
        />
      ))}
    </div>
  </div>

  <CustomSections page="property-detail" position="end" />

  {!sold && (
    <>
      <!-- STICKY MOBILE ENQUIRE BAR -->
      <div class="prop-sticky-bar" id="stickyEnquire">
        <div class="psb-name">{d.name} <span class="psb-loc">— {d.suburb}</span></div>
        <a href="#cform" class="psb-btn">Enquire &rarr;</a>
      </div>
      <script is:inline>
      document.addEventListener('astro:page-load', function () {
        var bar = document.getElementById('stickyEnquire');
        var form = document.getElementById('cform');
        if (!bar || !form || !('IntersectionObserver' in window)) return;
        var obs = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            bar.classList.toggle('psb-hidden', e.isIntersecting);
          });
        }, { threshold: 0.15 });
        obs.observe(form);
      });
      </script>
    </>
  )}
</Base>
