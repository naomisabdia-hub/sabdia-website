---
import Base from '../layouts/Base.astro';
import BenefitIcon from '../components/BenefitIcon.astro';
import CustomSections from '../components/CustomSections.astro';
import { wixResize, landLabel } from '../lib/wix.js';
import { getProperties } from '../lib/db.js';
import { getContent } from '../lib/content.js';

const [{ agent_page: page }, all] = await Promise.all([
  getContent('agent_page'),
  getProperties(),
]);
const forSale = all.filter((p) => p.data.status === 'for-sale').slice(0, 2);
---
<Base
  title="Agent Access | Sabdia Constructions"
  description="Exclusive agent access for real estate professionals. Pre-launch information, priority access, and commission structures for Sabdia Constructions luxury developments."
>
  <style is:inline slot="head">
  .agent-bens{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-top:64px}
  .agent-ben{padding:40px 32px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);transition:background .3s,border-color .3s}
  .agent-ben:hover{background:rgba(158,139,106,.06);border-color:rgba(158,139,106,.2)}
  .agent-ben-icon{width:44px;height:44px;border:1px solid rgba(196,172,135,.25);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--gold2);margin-bottom:20px}
  .agent-ben-t{font-family:var(--font-d);font-size:20px;font-weight:300;color:var(--white);margin-bottom:10px}
  .agent-ben-d{font-size:13px;font-weight:300;line-height:1.78;color:rgba(253,252,248,.4)}
  .agent-apply-grid{display:grid;grid-template-columns:1fr 1fr;gap:96px;align-items:start}
  @media(max-width:1024px){.agent-bens{grid-template-columns:repeat(2,1fr)}.agent-apply-grid{grid-template-columns:1fr;gap:52px}}
  @media(max-width:640px){.agent-bens{grid-template-columns:1fr}}
  .agent-listings-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
  @media(max-width:768px){.agent-listings-grid{grid-template-columns:1fr}}
  </style>

  <!-- HERO (dark, full) -->
  <section style="position:relative;min-height:100svh;display:flex;flex-direction:column;justify-content:flex-end;overflow:hidden;background:var(--dark)">
    <img src={page.hero.image} alt="Agent Access" loading="eager"
         style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:brightness(.28) saturate(.6)">
    <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(14,13,11,.95) 0%,rgba(14,13,11,.3) 60%,transparent 100%)"></div>
    <div class="inner" style="position:relative;z-index:2;padding:clamp(22px,5vw,80px);padding-bottom:clamp(72px,12vw,140px)">
      <div class="slabel slabel-dark reveal" style="margin-bottom:20px">{page.hero.label}</div>
      <h1 class="reveal d1" style="font-family:var(--font-d);font-size:clamp(52px,10vw,140px);font-weight:300;line-height:.88;letter-spacing:-.035em;color:var(--white)" set:html={page.hero.titleHtml} />
      <p class="reveal d2" style="font-size:13px;font-weight:300;color:rgba(253,252,248,.5);max-width:420px;margin-top:28px;line-height:1.85">{page.hero.text}</p>
    </div>
  </section>

  <CustomSections page="/agent-access/" position="top" />

  <!-- BENEFITS -->
  <section style="background:var(--dark2);padding:clamp(80px,12vw,160px) clamp(22px,5vw,80px)">
    <div class="inner">
      <div class="slabel slabel-dark reveal" style="margin-bottom:20px">{page.benefits.label}</div>
      <h2 class="reveal d1" style="font-family:var(--font-d);font-size:clamp(36px,5vw,64px);font-weight:300;color:var(--white);letter-spacing:-.02em;max-width:700px" set:html={page.benefits.headingHtml} />
      <div class="agent-bens">
        {page.benefits.items.map((b, i) => (
          <div class={`agent-ben reveal ${['', 'd1', 'd2', 'd1', 'd2', 'd3'][i % 6]}`.trim()}>
            <div class="agent-ben-icon">
              <BenefitIcon icon={b.icon} />
            </div>
            <div class="agent-ben-t">{b.title}</div>
            <div class="agent-ben-d">{b.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CURRENT LISTINGS PREVIEW -->
  <section class="sp" style="border-top:1px solid var(--border)">
    <div class="inner">
      <div class="slabel reveal" style="margin-bottom:20px">{page.listings.label}</div>
      <h2 class="about-h reveal d1" style="font-size:clamp(32px,4vw,52px);margin-bottom:48px" set:html={page.listings.headingHtml} />
      <div class="agent-listings-grid">
        {forSale.map((p, i) => (
          <a href={`/properties/${p.id}/`} class={`pc reveal ${i % 2 === 1 ? 'd1' : ''}`} style="aspect-ratio:16/10">
            <img src={wixResize(p.data.image, { w: 900, h: 560, focus: p.data.focus })} alt={p.data.name} loading="lazy">
            <div class="pc-ov"></div>
            <div class="pc-info">
              <div class="pc-status"><div class="pc-dot"></div>For Sale</div>
              <div class="pc-name">{p.data.name}</div>
              <div class="pc-loc">{p.data.suburb}, QLD &middot; {p.data.beds} Bed &middot; {p.data.baths} Bath &middot; {landLabel(p.data.land, p.data.landOver)}</div>
            </div>
            <div class="pc-arrow">&rarr;</div>
          </a>
        ))}
      </div>
      <div style="text-align:center;margin-top:28px">
        <a href={page.listings.cta.href} class="btn-g">{page.listings.cta.label} &rarr;</a>
      </div>
    </div>
  </section>

  <!-- APPLICATION FORM -->
  <section class="sp" style="background:var(--bg2);border-top:1px solid var(--border)" id="apply">
    <div class="inner agent-apply-grid">
      <div>
        <div class="slabel reveal">{page.apply.label}</div>
        <h2 class="about-h reveal d1" style="font-size:clamp(32px,4vw,52px)" set:html={page.apply.headingHtml} />
        <p class="about-p reveal d2">{page.apply.text}</p>
        <div class="reveal d3" style="margin-top:36px;padding:28px;background:var(--dark);border-left:2px solid var(--gold)">
          <div style="font-size:9px;font-weight:300;letter-spacing:.3em;text-transform:uppercase;color:var(--gold);margin-bottom:10px">{page.apply.noteLabel}</div>
          <div style="font-size:13px;font-weight:300;color:rgba(253,252,248,.5);line-height:1.75">{page.apply.noteText}</div>
        </div>
      </div>
      <div>
        <form class="cform reveal d1" id="cform" name="agent-application" method="POST" action="/api/contact">
          <input type="hidden" name="form-name" value="agent-application">
          <p class="hidden" style="display:none" aria-hidden="true"><label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off"></label></p>
          <div class="frow">
            <div class="fg"><label class="fl" for="aa-first">First Name*</label><input type="text" id="aa-first" name="first-name" class="fi" placeholder="First name" autocomplete="given-name" required></div>
            <div class="fg"><label class="fl" for="aa-last">Last Name*</label><input type="text" id="aa-last" name="last-name" class="fi" placeholder="Last name" autocomplete="family-name" required></div>
          </div>
          <div class="fg"><label class="fl" for="aa-agency">Agency / Company*</label><input type="text" id="aa-agency" name="agency" class="fi" placeholder="Agency or company name" autocomplete="organization" required></div>
          <div class="fg"><label class="fl" for="aa-email">Email Address*</label><input type="email" id="aa-email" name="email" class="fi" placeholder="your@email.com" autocomplete="email" required></div>
          <div class="fg"><label class="fl" for="aa-phone">Phone Number*</label><input type="tel" id="aa-phone" name="phone" class="fi" placeholder="+61 4xx xxx xxx" autocomplete="tel" required></div>
          <div class="fg"><label class="fl" for="aa-licence">Real Estate Licence No.*</label><input type="text" id="aa-licence" name="licence-number" class="fi" placeholder="Your licence number" autocomplete="off" required></div>
          <div class="fg">
            <label class="fl" for="aa-suburbs">Primary Suburb Markets</label>
            <input type="text" id="aa-suburbs" name="suburb-markets" class="fi" placeholder="e.g. Coorparoo, Camp Hill, New Farm…">
          </div>
          <div class="fg"><label class="fl" for="aa-message">Additional Information</label><textarea class="fta" id="aa-message" name="message" placeholder="Tell us about your client base, experience with luxury property, or any other relevant information…"></textarea></div>
          <button type="submit" class="fsub" id="fsub">{page.apply.submitLabel} &rarr;</button>
          <p class="sr-status" role="status" aria-live="polite" data-form-status></p>
        </form>
      </div>
    </div>
  </section>

  <CustomSections page="/agent-access/" position="end" />
</Base>
