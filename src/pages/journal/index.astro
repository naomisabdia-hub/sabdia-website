---
import Base from '../../layouts/Base.astro';
import { getPosts, readingTime, postDate } from '../../lib/blog.js';
import { imgVariant } from '../../lib/images.js';

const posts = await getPosts();
const [lead, ...rest] = posts;

const heroFor = (p, w, h) => (p.hero_image ? imgVariant(p.hero_image, { w, h, q: 84 }) : '');
---
<Base
  title="The Sabdia Journal | Sabdia Constructions"
  description="Notes from the Sabdia studio — new releases, completed residences, and ideas in luxury living from Brisbane's boutique luxury home builder and developer."
  ogTitle="The Sabdia Journal"
  ogDescription="Notes from the Sabdia studio — new releases, completed residences, and ideas in luxury living."
  lightNav
>
  <!-- HERO — same warm stone treatment as the contact page. -->
  <section style="padding:clamp(140px,20vw,200px) clamp(22px,5vw,80px) clamp(52px,8vw,96px);background:var(--bg3);border-bottom:1px solid var(--border)">
    <div class="inner">
      <div class="slabel reveal" style="margin-bottom:20px">Notes from the studio</div>
      <h1 class="reveal d1" style="font-family:var(--font-d);font-size:clamp(52px,10vw,140px);font-weight:300;line-height:.9;letter-spacing:-.035em;color:var(--ink)">The <em style="font-style:italic">Journal</em>.</h1>
      <p class="reveal d2" style="font-size:15.5px;font-weight:400;color:var(--ink3);max-width:460px;margin-top:28px;line-height:1.85">New releases, completed residences, and ideas in luxury living — written by the team designing and building them.</p>
    </div>
  </section>

  <section class="sp">
    <div class="inner">
      {posts.length === 0 && (
        <div style="text-align:center;padding:clamp(48px,8vw,96px) 0">
          <div class="slabel reveal" style="justify-content:center">First edition coming soon</div>
          <p class="reveal d1" style="font-family:'EB Garamond',Georgia,serif;font-style:italic;font-size:clamp(19px,2.4vw,26px);color:var(--ink2);max-width:520px;margin:18px auto 0;line-height:1.6">
            We're writing the first entries now. Join the list below and we'll send them to you first.
          </p>
        </div>
      )}

      {lead && (
        <a href={`/journal/${lead.slug}/`} class="jn-lead reveal">
          {lead.hero_image && <img src={heroFor(lead, 1400, 900)} alt={lead.hero_alt || lead.title} loading="eager" width="1400" height="900">}
          <div class="jn-lead-body">
            <div class="jn-meta">
              {lead.category && <span class="jn-cat">{lead.category}</span>}
              <span>{postDate(lead)}</span>
              <span>·</span>
              <span>{readingTime(lead.body)}</span>
            </div>
            <h2 class="jn-lead-h">{lead.title}</h2>
            <p class="jn-ex">{lead.excerpt}</p>
            <span class="jn-more">Read the entry &rarr;</span>
          </div>
        </a>
      )}

      {rest.length > 0 && (
        <div class="jn-grid">
          {rest.map((p, i) => (
            <a href={`/journal/${p.slug}/`} class={`jn-card reveal ${['', 'd1', 'd2'][i % 3]}`.trim()}>
              {p.hero_image && <img src={heroFor(p, 900, 620)} alt={p.hero_alt || p.title} loading="lazy" decoding="async" width="900" height="620">}
              <div class="jn-meta">
                {p.category && <span class="jn-cat">{p.category}</span>}
                <span>{postDate(p)}</span>
                <span>·</span>
                <span>{readingTime(p.body)}</span>
              </div>
              <h3 class="jn-card-h">{p.title}</h3>
              <p class="jn-ex">{p.excerpt}</p>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Base>
