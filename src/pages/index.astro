---
import Base from '../layouts/Base.astro';
import PropertyCard from '../components/PropertyCard.astro';
import SoldCard from '../components/SoldCard.astro';
import ServiceIcon from '../components/ServiceIcon.astro';
import FilmBand from '../components/FilmBand.astro';
import { landLabel } from '../lib/wix.js';
import { getProperties } from '../lib/db.js';
import { getContent, getServices, getProcessSteps, getTestimonials } from '../lib/content.js';

const [all, content, services, processSteps, testimonials] = await Promise.all([
  getProperties(),
  getContent(
    'settings',
    'home_hero',
    'home_stats',
    'home_marquee',
    'home_about',
    'home_properties',
    'home_services',
    'home_process',
    'home_agent',
    'home_contact',
    'films',
  ),
  getServices(),
  getProcessSteps(),
  getTestimonials(),
]);
const {
  settings,
  home_hero: heroC,
  home_stats: stats,
  home_marquee: marquee,
  home_about: about,
  home_properties: propsC,
  home_services: servicesC,
  home_process: processC,
  home_agent: agent,
  home_contact: contactC,
  films,
} = content;
const testimonial = testimonials[0];

const forSale = all.filter((p) => p.data.status === 'for-sale');
const sold = all.filter((p) => p.data.status === 'sold');

const hero = forSale[0];
const smallA = forSale[1];
const smallB = forSale[2];
const restRow = forSale.slice(3);

const heroPreload = heroC.slides[0]?.image;
const delays = ['', 'd1', 'd2', 'd3', 'd4', 'd5'];

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${settings.domainUrl}/#org`,
  name: settings.siteName,
  image: settings.jsonLdImage,
  url: `${settings.domainUrl}/`,
  telephone: settings.phone,
  address: { '@type': 'PostalAddress', addressLocality: 'Brisbane', addressRegion: 'QLD', addressCountry: 'AU' },
  description: settings.jsonLdDescription,
  sameAs: [settings.socials.instagram.url, settings.socials.facebook.url, settings.socials.linkedin.url],
  foundingDate: String(settings.estYear),
  areaServed: settings.areaServed,
});
---
<Base
  title={settings.seo.title}
  description={settings.seo.description}
  ogTitle={settings.seo.ogTitle}
  ogDescription={settings.seo.ogDescription}
  ogImage={settings.seo.ogImage}
  preloadImage={heroPreload}
>
  <script type="application/ld+json" slot="head" is:inline set:html={jsonLd} />

  <!-- HERO -->
  <section class="hero" id="hero">
    <div class="h-slides" id="hSlides">
      {heroC.slides.map((slide, i) => (
        <div class={`h-slide${i === 0 ? ' active' : ''}`}>
          <img
            src={slide.image}
            alt={slide.alt}
            loading={i === 0 ? 'eager' : 'lazy'}
            fetchpriority={i === 0 ? 'high' : undefined}
            decoding={i === 0 ? undefined : 'async'}
          >
        </div>
      ))}
    </div>
    <div class="h-overlay"></div>

    <!-- Middle: centred tagline + eyebrow below -->
    <div class="h-mid">
      <div class="h-mid-content">
        <h1 class="h-title">
          {heroC.words.map((word, i) => (
            <>
              {i > 0 && <span class="h-title-dot h-w"><span class="h-w-in" style={`--wi:${i * 2 - 1}`}>&nbsp;·&nbsp;</span></span>}
              <span class="h-w"><span class="h-w-in" style={`--wi:${i * 2}`}>{word}</span></span>
            </>
          ))}
        </h1>
        <p class="h-eyebrow-txt">{heroC.eyebrow}</p>
      </div>
    </div>

    <!-- Bottom zone: description above line, then gold line, then action bar -->
    <div class="h-bottom">
      <div class="h-desc-bar inner">
        <p class="h-desc">{heroC.description}</p>
      </div>
      <div class="h-bottom-rule"></div>
      <div class="h-bottom-inner inner">
        <div class="h-bottom-left">
          <div class="h-dots" id="hDots">
            {heroC.slides.map((_, i) => (
              <button type="button" class={`h-dot${i === 0 ? ' active' : ''}`} aria-label={`Show slide ${i + 1} of ${heroC.slides.length}`}></button>
            ))}
          </div>
          <p class="h-award"><em>{heroC.award}</em></p>
        </div>
        <div class="h-actions">
          <a href={heroC.primaryCta.href} class="btn-p">{heroC.primaryCta.label} &rarr;</a>
          <a href={heroC.secondaryCta.href} class="btn-g btn-g-light">{heroC.secondaryCta.label}</a>
        </div>
      </div>
    </div>
    <div class="h-scroll-wrap">
      <span class="h-scroll-num">01 / {String(heroC.slides.length).padStart(2, '0')}</span>
      <div class="h-scroll-line"></div>
    </div>
  </section>

  <!-- STATS -->
  <div class="stats-band sp-sm">
    <div class="stats-grid inner">
      {stats.items.map((s, i) => (
        <div class={`stat reveal ${delays[i]}`.trim()}>
          <span class="stat-n">
            {s.count
              ? <span class="counter" data-target={s.target}>0</span>
              : s.target}<span class="stat-u">{s.suffix}</span>
          </span>
          <div class="stat-l">{s.label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- MARQUEE -->
  <div class="mq-band">
    <div class="mq-track">
      {[false, true].map((dup) => (
        <div class="mq-group" aria-hidden={dup ? 'true' : undefined}>
          {marquee.items.map((item, i) => (
            <>
              {i > 0 && <div class="mq-sep"></div>}
              <div class="mq-item"><svg width="10" height="10" viewBox="0 0 14 14" fill="#9E8B6A" aria-hidden="true"><polygon points="7,1 8.8,5.6 13.7,5.6 9.9,8.5 11.2,13.4 7,10.5 2.8,13.4 4.1,8.5 0.3,5.6 5.2,5.6"/></svg>{item}</div>
            </>
          ))}
          <div class="mq-sep"></div>
        </div>
      ))}
    </div>
  </div>

  <!-- ABOUT -->
  <section class="sp" id="about">
    <div class="inner about-grid">
      <div class="about-sticky">
        <div class="slabel reveal">{about.label}</div>
        <h2 class="about-h reveal d1" set:html={about.headingHtml} />
        <div class="about-img-strip reveal d2">
          {about.images.map((img) => (
            <img src={img.image} alt={img.alt} loading="lazy" decoding="async">
          ))}
        </div>
      </div>
      <div>
        {about.paragraphs.map((p) => (
          <p class="about-p reveal d2">{p}</p>
        ))}
        <div class="sig reveal d3">
          <div class="sig-name">{about.sigName}</div>
          <div class="sig-title">{about.sigTitle}</div>
        </div>
        <div class="about-vals reveal d4">
          {about.values.map((v) => (
            <div class="about-val">
              <span class="about-val-n">{v.n}</span>
              <div><div class="about-val-t">{v.title}</div><div class="about-val-d">{v.desc}</div></div>
            </div>
          ))}
        </div>
        <div class="reveal d5" style="margin-top:40px">
          <a href={about.cta.href} class="btn-g">{about.cta.label} &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- BRAND FILM -->
  {films?.brand?.video && (
    <FilmBand
      id="story"
      label={films.brand.label}
      headingHtml={films.brand.headingHtml}
      text={films.brand.text}
      video={films.brand.video}
      poster={films.brand.poster}
      captionLeft="Sabdia — On Film"
      captionRight="Brisbane, QLD"
    >
      <a href="/collection/" class="btn-g btn-g-light reveal d3">Explore the Collection &rarr;</a>
    </FilmBand>
  )}

  <!-- PROPERTIES -->
  <section id="properties" style="padding:0 0 clamp(80px,12vw,160px)">
    <div class="inner" style="padding:clamp(80px,12vw,160px) clamp(22px,5vw,80px) clamp(44px,5vw,60px)">
      <div class="proj-hdr">
        <div>
          <div class="slabel reveal">{propsC.label}</div>
          <h2 class="proj-h reveal d1" set:html={propsC.headingHtml} />
        </div>
        <a href={propsC.cta.href} class="btn-g reveal d2">{propsC.cta.label} &rarr;</a>
      </div>
    </div>

    <div class="inner" style="padding:0 clamp(22px,5vw,80px)">
      <div class="proj-grid proj-grid-main reveal">
        {hero && (
          <PropertyCard
            entry={hero}
            class="pc-hero"
            imgW={1400}
            imgH={900}
            specs={[`${hero.data.beds} Bed`, `${hero.data.baths} Bath`, `${hero.data.cars} Garage`, landLabel(hero.data.land, hero.data.landOver)]}
            sep="dot"
          />
        )}
        {smallA && (
          <PropertyCard
            entry={smallA}
            class="pc-sm-a"
            style="aspect-ratio:4/3"
            imgW={900}
            imgH={680}
            specs={[`${smallA.data.beds} Bed`, `${smallA.data.baths} Bath`, landLabel(smallA.data.land, smallA.data.landOver)]}
            sep="dot"
          />
        )}
        {smallB && (
          <PropertyCard
            entry={smallB}
            class="pc-sm-b"
            style="aspect-ratio:4/3"
            imgW={900}
            imgH={680}
            specs={[`${smallB.data.beds} Bed`, `${smallB.data.baths} Bath`, landLabel(smallB.data.land, smallB.data.landOver)]}
            sep="dot"
          />
        )}
      </div>

      {(restRow.length > 0 || sold.length > 0) && (
        <div style="margin-top:10px;display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px">
          {restRow.map((p) => (
            <PropertyCard
              entry={p}
              class="reveal"
              style="aspect-ratio:16/10"
              imgW={900}
              imgH={560}
              specs={[`${p.data.beds} Bed`, `${p.data.baths} Bath`, landLabel(p.data.land, p.data.landOver)]}
              sep="dot"
            />
          ))}
          {sold.map((p, i) => (
            <SoldCard entry={p} class={`reveal ${['d1', 'd2'][i % 2]}`} imgW={800} imgH={500} showSuburb={false} />
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- SERVICES (dark section) -->
  <section class="svc-dark sp" id="services">
    <div class="inner svc-layout">
      <div class="svc-sticky">
        <div class="slabel reveal">{servicesC.label}</div>
        <h2 class="svc-h reveal d1" set:html={servicesC.headingHtml} />
        <p class="svc-p reveal d2">{servicesC.text}</p>
        <div class="reveal d3" style="margin-top:40px">
          <a href={servicesC.cta.href} class="btn-g" style="margin-top:8px">{servicesC.cta.label} &rarr;</a>
        </div>
      </div>
      <ul class="svc-list">
        {services.map((s, i) => (
          <li class={`svc-item reveal ${delays[i]}`.trim()}>
            <span class="svc-n">{s.number}</span>
            <div>
              <div class="svc-t">{s.title}</div>
              <div class="svc-d">{s.description}</div>
            </div>
            <div class="svc-icon">
              <ServiceIcon icon={s.icon} />
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="sp">
    <div class="inner">
      <div class="slabel reveal" style="margin-bottom:56px">{processC.label}</div>
      <div class="proc-track">
        {processSteps.map((step, i) => (
          <div class={`proc-step reveal ${delays[i]}`.trim()}>
            <div class="proc-n">{i + 1}</div>
            <div class="proc-t">{step.title}</div>
            <div class="proc-d">{step.description}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL (dark) -->
  {testimonial && (
    <section class="testi-dark sp">
      <div class="inner">
        <div class="testi-wrap">
          <div>
            <span class="testi-q-mark reveal">&ldquo;</span>
          </div>
          <div>
            <blockquote class="testi-text reveal d1">{testimonial.quote}</blockquote>
            <div class="testi-auth reveal d2">
              <div class="testi-line"></div>
              <div class="testi-name">{testimonial.attribution}</div>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- AGENT ACCESS -->
  <div class="agent-grid" id="agents">
    <div class="agent-vis reveal-x">
      <img src={agent.image.image} alt={agent.image.alt} loading="lazy" decoding="async">
      <div class="agent-frame"></div>
      <div class="agent-badge">{agent.badge}</div>
    </div>
    <div class="agent-content">
      <div class="slabel reveal">{agent.label}</div>
      <h2 class="agent-h reveal d1" set:html={agent.headingHtml} />
      <p class="agent-p reveal d2">{agent.text}</p>
      <ul class="agent-feats reveal d3">
        {agent.features.map((f) => (
          <li>{f}</li>
        ))}
      </ul>
      <div class="agent-btns reveal d4">
        <a href={agent.primaryCta.href} class="btn-p">{agent.primaryCta.label}</a>
        <a href={agent.secondaryCta.href} class="btn-g">{agent.secondaryCta.label}</a>
      </div>
    </div>
  </div>

  <!-- CONTACT CTA -->
  <section class="sp" id="contact" style="background:var(--bg2);border-top:1px solid var(--border)">
    <div class="inner contact-grid">
      <div>
        <div class="slabel reveal">{contactC.label}</div>
        <h2 class="contact-h reveal d1" set:html={contactC.headingHtml} />
        <p class="about-p reveal d2" style="margin-bottom:36px">{contactC.text}</p>
        <ul class="cdet reveal d3">
          <li class="cd"><span class="cd-l">Location</span><span class="cd-v">{settings.location}</span></li>
          <li class="cd"><span class="cd-l">Instagram</span><a href={settings.socials.instagram.url} target="_blank" class="cd-v">{settings.socials.instagram.label}</a></li>
          <li class="cd"><span class="cd-l">Facebook</span><a href={settings.socials.facebook.url} target="_blank" class="cd-v">{settings.socials.facebook.label}</a></li>
          <li class="cd"><span class="cd-l">LinkedIn</span><a href={settings.socials.linkedin.url} target="_blank" class="cd-v">{settings.socials.linkedin.label}</a></li>
        </ul>
      </div>
      <div>
        <form class="cform reveal d1" id="cform" name="contact" method="POST" action="/api/contact">
          <input type="hidden" name="form-name" value="contact">
          <p class="hidden" style="display:none" aria-hidden="true"><label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off"></label></p>
          <div class="frow">
            <div class="fg"><label class="fl" for="cf-first">First Name*</label><input type="text" id="cf-first" name="first-name" class="fi" placeholder="First name" autocomplete="given-name" required></div>
            <div class="fg"><label class="fl" for="cf-last">Last Name*</label><input type="text" id="cf-last" name="last-name" class="fi" placeholder="Last name" autocomplete="family-name" required></div>
          </div>
          <div class="fg"><label class="fl" for="cf-email">Email*</label><input type="email" id="cf-email" name="email" class="fi" placeholder="Email address" autocomplete="email" required></div>
          <div class="fg"><label class="fl" for="cf-phone">Phone</label><input type="tel" id="cf-phone" name="phone" class="fi" placeholder="Phone number" autocomplete="tel"></div>
          <div class="fg">
            <label class="fl" for="cf-interest">Interest</label>
            <select class="fsel" id="cf-interest" name="enquiry-type">
              {contactC.interests.map((opt) => (
                <option>{opt}</option>
              ))}
            </select>
          </div>
          <div class="fg"><label class="fl" for="cf-message">Message*</label><textarea class="fta" id="cf-message" name="message" placeholder="Tell us about your interest..." required></textarea></div>
          <button type="submit" class="fsub" id="fsub">Submit &rarr;</button>
          <p class="sr-status" role="status" aria-live="polite" data-form-status></p>
          <p class="form-note">{contactC.note}</p>
        </form>
      </div>
    </div>
  </section>
</Base>
