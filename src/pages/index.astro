---
import Base from '../layouts/Base.astro';
import PropertyCard from '../components/PropertyCard.astro';
import SoldCard from '../components/SoldCard.astro';
import { landLabel } from '../lib/wix.js';
import { getProperties } from '../lib/db.js';

const all = await getProperties();
const forSale = all.filter((p) => p.data.status === 'for-sale');
const sold = all.filter((p) => p.data.status === 'sold');

const hero = forSale[0];
const smallA = forSale[1];
const smallB = forSale[2];
const restRow = forSale.slice(3);

const heroPreload = 'https://static.wixstatic.com/media/1cc2db_4e48586f78704fc3ae5d00ddb8a125ee~mv2.jpg/v1/fill/w_1920,h_1080,al_c,q_85/1cc2db_4e48586f78704fc3ae5d00ddb8a125ee~mv2.jpg';

const mqItems = [
  'Multi-Award Winning',
  'Design · Develop · Construct',
  'Inner Brisbane Specialist',
  '100+ Residences Since 2013',
  'Boutique Luxury Developer',
];

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': 'https://www.sabdiaconstructions.com.au/#org',
  name: 'Sabdia Constructions',
  image: 'https://static.wixstatic.com/media/1cc2db_4e48586f78704fc3ae5d00ddb8a125ee~mv2.jpg',
  url: 'https://www.sabdiaconstructions.com.au/',
  telephone: '',
  address: { '@type': 'PostalAddress', addressLocality: 'Brisbane', addressRegion: 'QLD', addressCountry: 'AU' },
  description: 'Boutique luxury home builder and developer in inner Brisbane. Multi-award winning, 100+ residences delivered since 2013.',
  sameAs: [
    'https://www.instagram.com/_sabdia/',
    'https://www.facebook.com/sabdiaconstructions/',
    'https://www.linkedin.com/company/sabdia-constructions/',
  ],
  foundingDate: '2013',
  areaServed: 'Brisbane, Queensland, Australia',
});
---
<Base
  title="Sabdia Constructions | Luxury Home Builders &amp; Developers, Brisbane"
  description="Boutique luxury home builder and developer in inner Brisbane. Multi-award winning, 100+ residences delivered since 2013. Design, Develop, Construct."
  ogTitle="Sabdia Constructions — Luxury Home Builders, Brisbane"
  ogDescription="Boutique luxury home builder and developer in inner Brisbane. Multi-award winning, 100+ residences delivered since 2013."
  ogImage="https://static.wixstatic.com/media/1cc2db_4e48586f78704fc3ae5d00ddb8a125ee~mv2.jpg/v1/fill/w_1200,h_630,al_c,q_85/1cc2db_4e48586f78704fc3ae5d00ddb8a125ee~mv2.jpg"
  preloadImage={heroPreload}
>
  <script type="application/ld+json" slot="head" is:inline set:html={jsonLd} />

  <!-- HERO -->
  <section class="hero" id="hero">
    <div class="h-slides" id="hSlides">
      <div class="h-slide active">
        <img src={heroPreload} alt="Sabdia luxury home" loading="eager" fetchpriority="high">
      </div>
      <div class="h-slide">
        <img src="https://static.wixstatic.com/media/1cc2db_9e730867446c414c9fe72c1549cb7261~mv2.jpg/v1/fill/w_1920,h_1080,al_c,q_85/1cc2db_9e730867446c414c9fe72c1549cb7261~mv2.jpg" alt="Sabdia luxury home" loading="lazy">
      </div>
      <div class="h-slide">
        <img src="https://static.wixstatic.com/media/1cc2db_5186783e26c04be6ab983f26b9b78377~mv2.jpg/v1/fill/w_1920,h_1080,al_c,q_85/1cc2db_5186783e26c04be6ab983f26b9b78377~mv2.jpg" alt="Sabdia luxury home" loading="lazy">
      </div>
    </div>
    <div class="h-overlay"></div>

    <!-- Middle: centred tagline + eyebrow below -->
    <div class="h-mid">
      <div class="h-mid-content">
        <h1 class="h-title">Design<span class="h-title-dot"> · </span>Develop<span class="h-title-dot"> · </span>Construct</h1>
        <p class="h-eyebrow-txt">Boutique Luxury Home Builder &amp; Developer — Brisbane</p>
      </div>
    </div>

    <!-- Bottom zone: description above line, then gold line, then action bar -->
    <div class="h-bottom">
      <div class="h-desc-bar inner">
        <p class="h-desc">Redefining luxury through design, detail, and craftsmanship. For over ten years, Sabdia has delivered award-winning residences that set a new benchmark for contemporary living in Brisbane.</p>
      </div>
      <div class="h-bottom-rule"></div>
      <div class="h-bottom-inner inner">
        <div class="h-bottom-left">
          <div class="h-dots" id="hDots">
            <div class="h-dot active"></div>
            <div class="h-dot"></div>
            <div class="h-dot"></div>
          </div>
          <p class="h-award"><em>Award-Winning Luxury Residences.</em></p>
        </div>
        <div class="h-actions">
          <a href="/properties/" class="btn-p">View Properties &rarr;</a>
          <a href="/contact/" class="btn-g btn-g-light">Begin a Conversation</a>
        </div>
      </div>
    </div>
    <div class="h-scroll-wrap">
      <span class="h-scroll-num">01 / 03</span>
      <div class="h-scroll-line"></div>
    </div>
  </section>

  <!-- STATS -->
  <div class="stats-band sp-sm">
    <div class="stats-grid inner">
      <div class="stat reveal">
        <span class="stat-n"><span class="counter" data-target="10">0</span><span class="stat-u">+</span></span>
        <div class="stat-l">Years in Brisbane</div>
      </div>
      <div class="stat reveal d1">
        <span class="stat-n"><span class="counter" data-target="100">0</span><span class="stat-u">+</span></span>
        <div class="stat-l">Residences Delivered</div>
      </div>
      <div class="stat reveal d2">
        <span class="stat-n"><span class="counter" data-target="5">0</span><span class="stat-u">★</span></span>
        <div class="stat-l">Multi-Award Winning</div>
      </div>
      <div class="stat reveal d3">
        <span class="stat-n">100<span class="stat-u">%</span></span>
        <div class="stat-l">In-House Delivery</div>
      </div>
    </div>
  </div>

  <!-- MARQUEE -->
  <div class="mq-band">
    <div class="mq-track">
      {[...mqItems, ...mqItems].map((item, i) => (
        <>
          {i > 0 && <div class="mq-sep"></div>}
          <div class="mq-item"><svg width="10" height="10" viewBox="0 0 14 14" fill="#9E8B6A"><polygon points="7,1 8.8,5.6 13.7,5.6 9.9,8.5 11.2,13.4 7,10.5 2.8,13.4 4.1,8.5 0.3,5.6 5.2,5.6"/></svg>{item}</div>
        </>
      ))}
    </div>
  </div>

  <!-- ABOUT -->
  <section class="sp" id="about">
    <div class="inner about-grid">
      <div class="about-sticky">
        <div class="slabel reveal">About Sabdia</div>
        <h2 class="about-h reveal d1">Crafting <em>Exquisite</em><br>Living Spaces.</h2>
        <div class="about-img-strip reveal d2">
          <img src="https://static.wixstatic.com/media/1cc2db_4e48586f78704fc3ae5d00ddb8a125ee~mv2.jpg/v1/fill/w_900,h_600,al_c,q_85/1cc2db_4e48586f78704fc3ae5d00ddb8a125ee~mv2.jpg" alt="Sabdia craftsmanship" loading="lazy">
          <img src="https://static.wixstatic.com/media/1cc2db_9e730867446c414c9fe72c1549cb7261~mv2.jpg/v1/fill/w_500,h_600,al_c,q_85/1cc2db_9e730867446c414c9fe72c1549cb7261~mv2.jpg" alt="Sabdia detail" loading="lazy">
        </div>
      </div>
      <div>
        <p class="about-p reveal d2">At Sabdia, we manage every step of the residential development journey in-house — from visionary design through to expert construction. This integrated approach allows us to maintain meticulous control over quality, timing, and innovation, delivering homes that stand the test of time.</p>
        <p class="about-p reveal d2">With a focus on creating exceptional living spaces, Sabdia Constructions is dedicated to shaping the future of residential developments through innovation, quality, and unparalleled craftsmanship. Every project begins with a deep understanding of both the site and the clients who will call it home.</p>
        <p class="about-p reveal d2">We are not merely builders — we are creators of legacy. Each residence we deliver is conceived as a singular work of architecture, thoughtfully designed to complement its surroundings and exceed every expectation of luxury living.</p>
        <div class="sig reveal d3">
          <div class="sig-name">Sabdia</div>
          <div class="sig-title">Founder &amp; Principal</div>
        </div>
        <div class="about-vals reveal d4">
          <div class="about-val">
            <span class="about-val-n">i.</span>
            <div><div class="about-val-t">Integrated Delivery</div><div class="about-val-d">Design, develop, and construct under one roof — seamless from concept to keys.</div></div>
          </div>
          <div class="about-val">
            <span class="about-val-n">ii.</span>
            <div><div class="about-val-t">Uncompromising Quality</div><div class="about-val-d">Only the finest materials, master tradespeople, and meticulous attention to detail.</div></div>
          </div>
          <div class="about-val">
            <span class="about-val-n">iii.</span>
            <div><div class="about-val-t">Boutique &amp; Personal</div><div class="about-val-d">Limited projects annually to ensure every client receives our full dedication.</div></div>
          </div>
        </div>
        <div class="reveal d5" style="margin-top:40px">
          <a href="/about/" class="btn-g">Our Full Story &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- PROPERTIES -->
  <section id="properties" style="padding:0 0 clamp(80px,12vw,160px)">
    <div class="inner" style="padding:clamp(80px,12vw,160px) clamp(22px,5vw,80px) clamp(44px,5vw,60px)">
      <div class="proj-hdr">
        <div>
          <div class="slabel reveal">For Sale</div>
          <h2 class="proj-h reveal d1"><em>Current</em> Properties</h2>
        </div>
        <a href="/properties/" class="btn-g reveal d2">View All &rarr;</a>
      </div>
    </div>

    <div class="inner" style="padding:0 clamp(22px,5vw,80px)">
      <div class="proj-grid proj-grid-main reveal">
        {hero && (
          <PropertyCard
            entry={hero}
            class="pc-hero"
            imgW={1400}
            imgH={900}
            specs={[`${hero.data.beds} Bed`, `${hero.data.baths} Bath`, `${hero.data.cars} Garage`, landLabel(hero.data.land, hero.data.landOver)]}
            sep="dot"
          />
        )}
        {smallA && (
          <PropertyCard
            entry={smallA}
            class="pc-sm-a"
            style="aspect-ratio:4/3"
            imgW={900}
            imgH={680}
            specs={[`${smallA.data.beds} Bed`, `${smallA.data.baths} Bath`, landLabel(smallA.data.land, smallA.data.landOver)]}
            sep="dot"
          />
        )}
        {smallB && (
          <PropertyCard
            entry={smallB}
            class="pc-sm-b"
            style="aspect-ratio:4/3"
            imgW={900}
            imgH={680}
            specs={[`${smallB.data.beds} Bed`, `${smallB.data.baths} Bath`, landLabel(smallB.data.land, smallB.data.landOver)]}
            sep="dot"
          />
        )}
      </div>

      {(restRow.length > 0 || sold.length > 0) && (
        <div style="margin-top:10px;display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px">
          {restRow.map((p) => (
            <PropertyCard
              entry={p}
              class="reveal"
              style="aspect-ratio:16/10"
              imgW={900}
              imgH={560}
              specs={[`${p.data.beds} Bed`, `${p.data.baths} Bath`, landLabel(p.data.land, p.data.landOver)]}
              sep="dot"
            />
          ))}
          {sold.map((p, i) => (
            <SoldCard entry={p} class={`reveal ${['d1', 'd2'][i % 2]}`} imgW={800} imgH={500} showSuburb={false} />
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- SERVICES (dark section) -->
  <section class="svc-dark sp" id="services">
    <div class="inner svc-layout">
      <div class="svc-sticky">
        <div class="slabel reveal">What We Do</div>
        <h2 class="svc-h reveal d1">Full-spectrum<br><em>development</em><br>expertise.</h2>
        <p class="svc-p reveal d2">From site acquisition through to final handover, Sabdia manages every element in-house — ensuring seamless delivery and uncompromising quality at every stage.</p>
        <div class="reveal d3" style="margin-top:40px">
          <a href="/services/" class="btn-g" style="margin-top:8px">Explore Services &rarr;</a>
        </div>
      </div>
      <ul class="svc-list">
        <li class="svc-item reveal">
          <span class="svc-n">01</span>
          <div>
            <div class="svc-t">Luxury Residential Design</div>
            <div class="svc-d">Bespoke single residences and boutique developments designed for discerning clients. From architectural concept to interior finishing — every detail considered, nothing left to chance.</div>
          </div>
          <div class="svc-icon">
            <svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M1 7L7 1L13 7V13H9V9H5V13H1V7Z"/></svg>
          </div>
        </li>
        <li class="svc-item reveal d1">
          <span class="svc-n">02</span>
          <div>
            <div class="svc-t">Development Management</div>
            <div class="svc-d">End-to-end residential development managed from vision to completion. Our integrated in-house model maintains meticulous control over quality, timing, and innovation throughout.</div>
          </div>
          <div class="svc-icon">
            <svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.2"><rect x="1" y="3" width="12" height="10"/><path d="M4 3V1H10V3"/></svg>
          </div>
        </li>
        <li class="svc-item reveal d2">
          <span class="svc-n">03</span>
          <div>
            <div class="svc-t">Interior Architecture</div>
            <div class="svc-d">Integrated interior architecture that elevates every space. Our design team collaborates closely with builders to ensure perfect cohesion between vision and reality.</div>
          </div>
          <div class="svc-icon">
            <svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.2"><circle cx="7" cy="7" r="5.5"/><path d="M7 4.5V7L9 9"/></svg>
          </div>
        </li>
        <li class="svc-item reveal d3">
          <span class="svc-n">04</span>
          <div>
            <div class="svc-t">Expert Construction</div>
            <div class="svc-d">Premium construction by master tradespeople. We use only the finest materials and proven methodologies — delivered with full transparency and precision at every stage.</div>
          </div>
          <div class="svc-icon">
            <svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.2"><rect x="1" y="1" width="12" height="12"/><path d="M4 7h6M7 4v6"/></svg>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="sp">
    <div class="inner">
      <div class="slabel reveal" style="margin-bottom:56px">Our Process</div>
      <div class="proc-track">
        <div class="proc-step reveal">
          <div class="proc-n">1</div>
          <div class="proc-t">Design</div>
          <div class="proc-d">Visionary design that balances beauty, functionality, and long-term value. Every project begins with a deep understanding of site, context, and client.</div>
        </div>
        <div class="proc-step reveal d1">
          <div class="proc-n">2</div>
          <div class="proc-t">Develop</div>
          <div class="proc-d">We manage the complete development process in-house — approvals, planning, engineering — maintaining full control over every decision and outcome.</div>
        </div>
        <div class="proc-step reveal d2">
          <div class="proc-n">3</div>
          <div class="proc-t">Construct</div>
          <div class="proc-d">Precision construction by our own team of master tradespeople, using premium materials and meticulous quality control at every stage of the build.</div>
        </div>
        <div class="proc-step reveal d3">
          <div class="proc-n">4</div>
          <div class="proc-t">Deliver</div>
          <div class="proc-d">Handover marks the beginning of your story. Our aftercare ensures your home continues to perform and delight for decades to come.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL (dark) -->
  <section class="testi-dark sp">
    <div class="inner">
      <div class="testi-wrap">
        <div>
          <span class="testi-q-mark reveal">&ldquo;</span>
        </div>
        <div>
          <blockquote class="testi-text reveal d1">Sabdia delivered a home that exceeded every expectation. Their integrated approach — from design through to construction — meant every detail was perfectly executed. A truly exceptional result that we will treasure for generations.</blockquote>
          <div class="testi-auth reveal d2">
            <div class="testi-line"></div>
            <div class="testi-name">Satisfied Client — Inner Brisbane Residence</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- AGENT ACCESS -->
  <div class="agent-grid" id="agents">
    <div class="agent-vis reveal-x">
      <img src="https://static.wixstatic.com/media/1cc2db_7d6ddb5093af4f3eb6b9d3acd088be79~mv2.png/v1/fill/w_900,h_1100,q_85,enc_avif,quality_auto/1cc2db_7d6ddb5093af4f3eb6b9d3acd088be79~mv2.png" alt="Agent Access" loading="lazy">
      <div class="agent-frame"></div>
      <div class="agent-badge">Exclusive Access</div>
    </div>
    <div class="agent-content">
      <div class="slabel reveal">For Real Estate Professionals</div>
      <h2 class="agent-h reveal d1">Exclusive <em>Agent</em><br>Access.</h2>
      <p class="agent-p reveal d2">Gain exclusive insight into Sabdia's future releases. Our agent-only preview list offers early access to premium developments, pre-launch information, and priority communication — giving your clients an edge in Brisbane's luxury market.</p>
      <ul class="agent-feats reveal d3">
        <li>Pre-release access to upcoming developments</li>
        <li>Pre-launch pricing and floor plan information</li>
        <li>Priority communication on new releases</li>
        <li>Exclusive commission structures</li>
        <li>Invitations to private project previews</li>
        <li>Dedicated liaison with the Sabdia team</li>
      </ul>
      <div class="agent-btns reveal d4">
        <a href="/agent-access/" class="btn-p">Apply for Access</a>
        <a href="/contact/" class="btn-g">Learn More</a>
      </div>
    </div>
  </div>

  <!-- CONTACT CTA -->
  <section class="sp" id="contact" style="background:var(--bg2);border-top:1px solid var(--border)">
    <div class="inner contact-grid">
      <div>
        <div class="slabel reveal">Get In Touch</div>
        <h2 class="contact-h reveal d1">Let's start<br>a <em>conversation</em>.</h2>
        <p class="about-p reveal d2" style="margin-bottom:36px">Please submit your contact information and one of our team members will be in touch with you shortly.</p>
        <ul class="cdet reveal d3">
          <li class="cd"><span class="cd-l">Location</span><span class="cd-v">Brisbane, Queensland, Australia</span></li>
          <li class="cd"><span class="cd-l">Instagram</span><a href="https://www.instagram.com/_sabdia/" target="_blank" class="cd-v">@_sabdia</a></li>
          <li class="cd"><span class="cd-l">Facebook</span><a href="https://www.facebook.com/sabdiaconstructions/" target="_blank" class="cd-v">Sabdia Constructions</a></li>
          <li class="cd"><span class="cd-l">LinkedIn</span><a href="https://www.linkedin.com/company/sabdia-constructions/" target="_blank" class="cd-v">Sabdia Constructions</a></li>
        </ul>
      </div>
      <div>
        <form class="cform reveal d1" id="cform" name="contact" method="POST" action="/api/contact">
          <input type="hidden" name="form-name" value="contact">
          <p class="hidden" style="display:none"><label>Don't fill this out: <input name="bot-field"></label></p>
          <div class="frow">
            <div class="fg"><label class="fl">First Name*</label><input type="text" name="first-name" class="fi" placeholder="First name" required></div>
            <div class="fg"><label class="fl">Last Name*</label><input type="text" name="last-name" class="fi" placeholder="Last name" required></div>
          </div>
          <div class="fg"><label class="fl">Email*</label><input type="email" name="email" class="fi" placeholder="Email address" required></div>
          <div class="fg"><label class="fl">Phone</label><input type="tel" name="phone" class="fi" placeholder="Phone number"></div>
          <div class="fg">
            <label class="fl">Interest</label>
            <select class="fsel" name="enquiry-type">
              <option>For Sale — Current Properties</option>
              <option>Custom Home Design</option>
              <option>Development Partnership</option>
              <option>Agent Access</option>
              <option>General Enquiry</option>
            </select>
          </div>
          <div class="fg"><label class="fl">Message*</label><textarea class="fta" name="message" placeholder="Tell us about your interest..." required></textarea></div>
          <button type="submit" class="fsub" id="fsub">Submit &rarr;</button>
          <p class="form-note">We typically respond within one business day.</p>
        </form>
      </div>
    </div>
  </section>
</Base>
