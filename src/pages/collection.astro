---
import Base from '../layouts/Base.astro';
import CustomSections from '../components/CustomSections.astro';
import { getContent } from '../lib/content.js';

const { collection_page: page } = await getContent('collection_page');
const delays = ['', 'd1', 'd2'];
---
<Base
  title="Collection | Sabdia Constructions"
  description="The Sabdia Collection — a portfolio of completed luxury residences across inner Brisbane. Award-winning homes designed, developed, and constructed by Sabdia."
>
  <!-- Portfolio grid/card styles live in the global stylesheet
       (style.css → COLLECTION PORTFOLIO GRID) so the collection detail
       pages can reuse them. -->

  <!-- PAGE HEADER -->
  <section style="padding:clamp(130px,18vw,180px) clamp(22px,5vw,80px) clamp(48px,6vw,72px);background:var(--bg);border-bottom:1px solid var(--border)">
    <div class="inner">
      <div class="slabel reveal" style="margin-bottom:18px">{page.label}</div>
      <h1 class="reveal d1" style="font-family:var(--font-d);font-size:clamp(48px,9vw,120px);font-weight:300;line-height:.88;letter-spacing:-.035em;color:var(--ink)" set:html={page.titleHtml} />
      <p class="reveal d2" style="font-size:13.5px;font-weight:300;line-height:1.9;color:var(--ink3);max-width:480px;margin-top:28px">{page.text}</p>
    </div>
  </section>

  <CustomSections page="/collection/" position="top" />

  <!-- PORTFOLIO GRID -->
  <section style="padding:clamp(52px,7vw,96px) clamp(22px,5vw,80px) clamp(80px,12vw,140px);background:var(--bg)">
    <div class="inner">
      <div class="portfolio-grid">
        {page.items.map((item, i) => (
          <a href={`/collection/${item.name.toLowerCase().replace(/[^a-z0-9]+/g, '-')}/`} class={`port-card reveal ${delays[i % 3]}`} data-port-card>
            <div class="port-img-wrap">
              <img src={item.image} alt={item.name} loading="lazy">
              {item.video && <video src={item.video} muted loop playsinline preload="none" data-port-video></video>}
              {item.video && <span class="port-film-tag">Film</span>}
            </div>
            <div class="port-name">{item.name} <span style="color:var(--gold);font-weight:300">&rarr;</span></div>
            <div class="port-loc">{item.loc}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CustomSections page="/collection/" position="end" />

  <script is:inline>
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    document.querySelectorAll('[data-port-card]').forEach(function (card) {
      var video = card.querySelector('[data-port-video]');
      if (!video) return;
      card.addEventListener('mouseenter', function () {
        video.play().then(function () { video.classList.add('playing'); }).catch(function () {});
      });
      card.addEventListener('mouseleave', function () {
        video.pause();
        video.classList.remove('playing');
      });
    });
  })();
  </script>
</Base>
