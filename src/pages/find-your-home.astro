---
/**
 * Guided residence match — a question-led alternative to the classic
 * enquiry form (which remains untouched on /contact/).
 *
 * Flow: 5 questions (timeline, flexibility, bedrooms, budget, area)
 * → matched for-sale residences → contact details → submits to the
 * same /api/contact endpoint as every other form (form-name
 * "guided-match", answers serialised into the message body).
 *
 * Matching runs client-side over data-* attributes rendered per
 * property. If no residence matches on bedrooms/area, the full for-sale
 * collection is offered with an "upcoming releases" note.
 *
 * BUDGET GATE — the collection starts well above most enquiries, so a
 * visitor whose stated ceiling sits under BUDGET_FLOOR is not shown
 * residences at all. They are moved to a future-releases registration
 * instead: a real thing we can offer them, captured as a distinct lead
 * type, and worth more to both sides than a tour of homes out of reach.
 *
 * That path never states or implies a price. It does not say "our homes
 * start at X", does not apologise, and does not imply they fell short —
 * it simply offers first sight of what is coming. The floor is a
 * qualifying threshold held on our side, not a message to the visitor.
 */
import Base from '../layouts/Base.astro';
import CustomSections from '../components/CustomSections.astro';
import PropertyCard from '../components/PropertyCard.astro';
import { landLabel } from '../lib/images.js';
import { getProperties } from '../lib/db.js';
import { getContent } from '../lib/content.js';

const [{ find_home: fh }, all] = await Promise.all([getContent('find_home'), getProperties()]);
const forSale = all.filter((p) => p.data.status === 'for-sale');

/* Stated ceiling (in $m) below which we show no residences and offer the
   future-releases path instead. Kept here as a single number so it can be
   moved without touching copy — nothing user-facing derives from it. */
const BUDGET_FLOOR = 5.5;

// Suburb → area group used by the area question.
const AREA: Record<string, string> = {
  Coorparoo: 'inner-east',
  'Camp Hill': 'inner-east',
  Ascot: 'north',
  Hendra: 'north',
  'Holland Park West': 'south',
  'Holland Park': 'south',
};

const steps = [
  {
    key: 'timeline',
    q: 'When would you like to make your move?',
    options: ['Ready now', 'Within 3–6 months', 'Within a year', 'Just exploring'],
  },
  {
    key: 'flexibility',
    q: 'Would you consider a residence still under construction?',
    options: ['Completed homes only', 'Happy to watch it finish', 'Open to either'],
  },
  {
    key: 'bedrooms',
    q: 'How many bedrooms does your household need?',
    options: ['Four', 'Five', 'Six or more', 'Flexible'],
  },
  /* Budget is a slider asking for a CEILING, not a bracket. Brackets
     invite people to state a comfortable floor — someone who types "$2m"
     as what they'd like to spend may well stretch to $5m for the right
     home, and a bracket loses that entirely.

     The scale deliberately runs below where the collection actually
     starts. A slider that bottoms out at the real floor would announce
     it, and would leave anyone underneath with no honest answer to give.
     The handle rests above the threshold instead, so the scale reads as
     unremarkable while still anchoring upward — and a visitor who never
     touches it qualifies by default rather than being disqualified by
     inaction. See BUDGET_FLOOR below for what the answer actually gates. */
  {
    key: 'budget',
    type: 'slider',
    q: 'What is the most you would consider?',
    min: 2,
    max: 15,
    step: 0.5,
    start: 6,
  },
  {
    key: 'area',
    q: 'Which pocket of Brisbane calls to you?',
    options: ['Inner-East — Coorparoo, Camp Hill', 'North — Ascot, Hendra', 'South — Holland Park', 'Open to suggestions'],
  },
];
---
<Base
  title="Find Your Residence | Sabdia Constructions"
  description="Answer five short questions and we'll match you with the Sabdia residence that fits your timeline, household, and preferred pocket of Brisbane."
  lightNav
>
  <!-- PAGE HEADER -->
  <section style="padding:clamp(130px,18vw,180px) clamp(22px,5vw,80px) clamp(40px,5vw,64px);background:var(--bg2);border-bottom:1px solid var(--border)">
    <div class="inner-md" style="text-align:center">
      <div class="slabel reveal" style="justify-content:center">{fh.label}</div>
      <h1 class="reveal d1 fyh-title" style="font-family:var(--font-d);font-size:clamp(40px,7vw,84px);font-weight:300;line-height:.95;letter-spacing:-.03em;color:var(--ink)" set:html={fh.titleHtml} />
      <p class="reveal d2 fyh-sub" style="font-family:'EB Garamond',Georgia,serif;font-size:15.5px;font-weight:300;line-height:1.85;color:var(--ink3);max-width:480px;margin:20px auto 0" set:html={fh.subHtml} />
    </div>
  </section>

  <CustomSections page="/find-your-home/" position="top" />

  <!-- WIZARD -->
  <section class="sp-sm" style="min-height:60vh">
    <div class="inner-md">
      <!-- progress -->
      <div class="fyh-progress" data-fyh-progress aria-hidden="true">
        {steps.map((_, i) => <span class={`fyh-tick${i === 0 ? ' on' : ''}`}></span>)}
        <span class="fyh-tick"></span>
      </div>

      <form class="cform" id="cform" name="guided-match" method="POST" action="/api/contact" data-fyh data-fyh-floor={BUDGET_FLOOR}>
        <input type="hidden" name="form-name" value="guided-match">
        <input type="hidden" name="enquiry-type" value="Guided Match">
        <input type="hidden" name="message" data-fyh-message value="">
        <p class="hidden" style="display:none" aria-hidden="true"><label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off"></label></p>

        {steps.map((s, i) => (
          <fieldset class={`fyh-step${i === 0 ? ' on' : ''}`} data-fyh-step={s.key}>
            <legend class="fyh-q">{s.q}</legend>
            {s.type === 'slider' ? (
              <div class="fyh-slider">
                <output class="fyh-slider-val" data-fyh-slider-out for="fyh-budget"></output>
                <input
                  type="range"
                  class="fyh-range"
                  id="fyh-budget"
                  data-fyh-range
                  min={s.min}
                  max={s.max}
                  step={s.step}
                  value={s.start}
                  aria-label="Maximum you would consider, in millions of dollars"
                />
                <div class="fyh-slider-ends" aria-hidden="true">
                  <span>${s.min}m</span>
                  <span>${s.max}m+</span>
                </div>
                <button type="button" class="fyh-opt fyh-slider-go" data-fyh-slider-go>Continue</button>
              </div>
            ) : (
              <div class="fyh-opts">
                {s.options.map((o) => (
                  <button type="button" class="fyh-opt" data-fyh-answer={o}>{o}</button>
                ))}
              </div>
            )}
          </fieldset>
        ))}

        <!-- RESULTS + DETAILS -->
        <div class="fyh-step" data-fyh-results>
          <div class="fyh-q" data-fyh-results-heading>Residences that fit.</div>
          <p class="fyh-note" data-fyh-results-note></p>
          <div class="fyh-matches" data-fyh-matches>
            {forSale.map((p) => (
              <div
                data-fyh-card
                data-beds={p.data.beds}
                data-area={AREA[p.data.suburb] ?? 'other'}
              >
                <PropertyCard
                  entry={p}
                  style="aspect-ratio:16/10"
                  imgW={800}
                  imgH={500}
                  specs={[`${p.data.beds} Bed`, `${p.data.baths} Bath`, landLabel(p.data.land, p.data.landOver)]}
                />
              </div>
            ))}
          </div>

          <div class="fyh-details">
            <div class="fyh-q" style="font-size:clamp(20px,2.6vw,30px)" data-fyh-details-heading>Where shall we send your matches?</div>
            <div class="frow">
              <div class="fg"><label class="fl" for="fyh-first">First Name*</label><input type="text" id="fyh-first" name="first-name" class="fi" placeholder="First name" autocomplete="given-name" required></div>
              <div class="fg"><label class="fl" for="fyh-last">Last Name*</label><input type="text" id="fyh-last" name="last-name" class="fi" placeholder="Last name" autocomplete="family-name" required></div>
            </div>
            <div class="frow">
              <div class="fg"><label class="fl" for="fyh-email">Email*</label><input type="email" id="fyh-email" name="email" class="fi" placeholder="Email address" autocomplete="email" required></div>
              <div class="fg"><label class="fl" for="fyh-phone">Phone</label><input type="tel" id="fyh-phone" name="phone" class="fi" placeholder="Phone number" autocomplete="tel"></div>
            </div>
            <div class="fg"><label class="fl" for="fyh-notes">Anything else we should know?</label><textarea class="fta" id="fyh-notes" name="notes" placeholder="Land you already own, must-haves, questions…" style="min-height:88px"></textarea></div>
            <button type="submit" class="fsub" id="fsub" data-fyh-submit>Send My Matches &rarr;</button>
            <p class="sr-status" role="status" aria-live="polite" data-form-status></p>
            <p class="form-note" data-fyh-form-note>One of our team will be in touch within one business day.</p>
          </div>
        </div>

        <button type="button" class="fyh-back" data-fyh-back style="display:none">&larr; Back</button>
      </form>
    </div>
  </section>

  <CustomSections page="/find-your-home/" position="end" />

  <style is:inline>
    .fyh-title em{font-style:italic;color:var(--ink)}
    .fyh-sub a{color:var(--ink);border-bottom:1px solid rgba(41,35,25,.45)}
    .fyh-progress{display:flex;gap:10px;justify-content:center;margin-bottom:clamp(32px,5vw,56px)}
    .fyh-tick{width:26px;height:1.5px;background:var(--border);transition:background .4s}
    .fyh-tick.on{background:var(--gold)}
    .fyh-step{display:none;border:none;opacity:0;transform:translateY(14px)}
    .fyh-step.on{display:block;animation:fyhIn .55s var(--ease) forwards}
    @keyframes fyhIn{to{opacity:1;transform:translateY(0)}}
    .fyh-q{font-family:var(--font-d);font-size:clamp(24px,3.4vw,40px);font-weight:300;color:var(--ink);letter-spacing:-.015em;text-align:center;margin-bottom:clamp(24px,4vw,40px);width:100%}
    .fyh-opts{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px;max-width:760px;margin:0 auto}
    .fyh-opt{font-family:var(--font-u);font-size:11px;font-weight:300;letter-spacing:.18em;text-transform:uppercase;color:var(--ink2);background:var(--white);border:1px solid var(--border);padding:22px 18px;cursor:pointer;transition:border-color .3s,color .3s,transform .25s var(--ease)}
    .fyh-opt:hover{border-color:var(--ink);color:var(--ink);transform:translateY(-2px)}
    /* Budget slider. Styled as a hairline track with a gold handle to match
       the JourneySlider's timeline — the same gesture, so it reads as part
       of the house rather than a browser default control. */
    .fyh-slider{max-width:560px;margin:0 auto;display:flex;flex-direction:column;align-items:center}
    .fyh-slider-val{font-family:var(--font-d);font-size:clamp(30px,4.4vw,52px);font-weight:300;font-style:italic;color:var(--ink);letter-spacing:-.02em;line-height:1;margin-bottom:clamp(22px,3vw,32px)}
    .fyh-range{-webkit-appearance:none;appearance:none;width:100%;background:transparent;cursor:pointer;height:26px}
    .fyh-range::-webkit-slider-runnable-track{height:1px;background:var(--border)}
    .fyh-range::-moz-range-track{height:1px;background:var(--border)}
    .fyh-range::-moz-range-progress{height:1.5px;background:var(--gold)}
    .fyh-range::-webkit-slider-thumb{-webkit-appearance:none;appearance:none;width:26px;height:26px;margin-top:-12.5px;border-radius:50%;background:var(--bg);border:1px solid var(--gold);box-shadow:0 4px 14px rgba(31,27,20,.14);transition:transform .25s var(--ease)}
    .fyh-range::-moz-range-thumb{width:24px;height:24px;border-radius:50%;background:var(--bg);border:1px solid var(--gold);box-shadow:0 4px 14px rgba(31,27,20,.14)}
    .fyh-range:hover::-webkit-slider-thumb{transform:scale(1.08)}
    .fyh-range:focus-visible::-webkit-slider-thumb{outline:1.5px solid var(--gold);outline-offset:3px}
    .fyh-slider-ends{display:flex;justify-content:space-between;width:100%;margin-top:10px;font-size:9px;font-weight:300;letter-spacing:.24em;text-transform:uppercase;color:var(--taupe-d)}
    .fyh-slider-go{margin-top:clamp(30px,4vw,44px);min-width:220px}
    @media(prefers-reduced-motion:reduce){.fyh-range::-webkit-slider-thumb{transition:none}.fyh-range:hover::-webkit-slider-thumb{transform:none}}

    .fyh-note{font-family:'EB Garamond',Georgia,serif;font-size:15px;font-style:italic;color:var(--ink3);text-align:center;margin:-14px 0 26px}
    .fyh-matches{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:clamp(32px,5vw,52px)}
    .fyh-matches [data-fyh-card]{display:none}
    .fyh-matches [data-fyh-card].show{display:block}
    .fyh-details{max-width:640px;margin:0 auto;display:flex;flex-direction:column;gap:16px}
    .fyh-back{margin:34px auto 0;display:flex;background:none;border:none;font-family:var(--font-u);font-size:9.5px;font-weight:300;letter-spacing:.24em;text-transform:uppercase;color:var(--taupe-d);cursor:pointer;transition:color .3s;padding:6px}
    .fyh-back:hover{color:var(--ink)}
    @media(max-width:760px){.fyh-matches{grid-template-columns:1fr}.fyh-opts{grid-template-columns:1fr}}
    @media(prefers-reduced-motion:reduce){.fyh-step.on{animation:none;opacity:1;transform:none}}
  </style>

  <script is:inline>
  /* Re-runs per navigation — see main.js for why. */
  document.addEventListener('astro:page-load', function () {
    var form = document.querySelector('[data-fyh]');
    if (!form) return;
    var steps = [].slice.call(form.querySelectorAll('.fyh-step'));
    var ticks = [].slice.call(document.querySelectorAll('.fyh-tick'));
    var back = form.querySelector('[data-fyh-back]');
    var msgField = form.querySelector('[data-fyh-message]');
    var answers = {};
    var idx = 0;

    function show(i) {
      idx = i;
      steps.forEach(function (s, k) { s.classList.toggle('on', k === i); });
      ticks.forEach(function (t, k) { t.classList.toggle('on', k <= i); });
      back.style.display = i > 0 ? 'flex' : 'none';
      window.scrollTo({ top: form.getBoundingClientRect().top + window.scrollY - 140, behavior: 'smooth' });
      if (steps[i].hasAttribute('data-fyh-results')) buildResults();
    }

    steps.forEach(function (step, i) {
      [].slice.call(step.querySelectorAll('[data-fyh-answer]')).forEach(function (btn) {
        btn.addEventListener('click', function () {
          answers[step.dataset.fyhStep] = btn.dataset.fyhAnswer;
          show(i + 1);
        });
      });

      // Slider step: needs an explicit Continue, since there is no
      // discrete choice to advance on. Its default value counts as the
      // answer even if the visitor never drags — see the note on `start`.
      var range = step.querySelector('[data-fyh-range]');
      if (range) {
        var out = step.querySelector('[data-fyh-slider-out]');
        var paint = function () { out.textContent = fmtBudget(range); };
        range.addEventListener('input', paint);
        paint();
        step.querySelector('[data-fyh-slider-go]').addEventListener('click', function () {
          answers[step.dataset.fyhStep] = fmtBudget(range);
          answers[step.dataset.fyhStep + 'Value'] = Number(range.value);
          show(i + 1);
        });
      }
    });

    // "$7 million" / "$7.5 million" / "$15 million or more" at the ceiling.
    function fmtBudget(range) {
      var v = Number(range.value);
      var n = v % 1 === 0 ? String(v) : v.toFixed(1);
      return '$' + n + ' million' + (v >= Number(range.max) ? ' or more' : '');
    }
    back.addEventListener('click', function () { show(Math.max(0, idx - 1)); });

    function buildResults() {
      var cards = [].slice.call(form.querySelectorAll('[data-fyh-card]'));
      var note = form.querySelector('[data-fyh-results-note]');
      var heading = form.querySelector('[data-fyh-results-heading]');
      var shown = 0;
      /* Read off the form rather than injected via define:vars — an inline
         script cannot see frontmatter, and baking the value into the script
         body would make it page-specific (see WalkthroughCinema). */
      var BUDGET_FLOOR = Number(form.dataset.fyhFloor);
      var minBeds = { Four: 4, Five: 5, 'Six or more': 6 }[answers.bedrooms] || 0;
      var area = { 'Inner-East — Coorparoo, Camp Hill': 'inner-east', 'North — Ascot, Hendra': 'north', 'South — Holland Park': 'south' }[answers.area] || null;

      var detailsHeading = form.querySelector('[data-fyh-details-heading]');
      var submit = form.querySelector('[data-fyh-submit]');
      var formNote = form.querySelector('[data-fyh-form-note]');
      var enquiryType = form.querySelector('[name="enquiry-type"]');

      /* Below the floor: show no residences and offer first sight of what
         is coming instead. Every word here is true and none of it prices
         anything — no "from", no "starting at", no apology. A visitor
         should read this as an invitation, not a rejection, and should
         not be able to infer a number from it. */
      var belowFloor = answers.budgetValue !== undefined && answers.budgetValue < BUDGET_FLOOR;

      if (belowFloor) {
        cards.forEach(function (c) { c.classList.remove('show'); });
        heading.textContent = 'First sight of what’s next.';
        note.textContent = 'Much of what we build is placed privately, before it is ever listed. Tell us where to reach you and we will bring our upcoming residences to you first.';
        detailsHeading.textContent = 'Where shall we reach you?';
        submit.innerHTML = 'Register My Interest &rarr;';
        formNote.textContent = 'We will be in touch as new residences come out of design.';
        enquiryType.value = 'Future Releases';
      } else {
        var matched = cards.filter(function (c) {
          if (minBeds && Number(c.dataset.beds) < minBeds) return false;
          if (area && c.dataset.area !== area) return false;
          return true;
        });

        var showing = matched.length ? matched : cards;
        cards.forEach(function (c) { c.classList.toggle('show', showing.indexOf(c) !== -1); });

        if (matched.length) {
          heading.textContent = matched.length === 1 ? 'One residence fits beautifully.' : 'Residences that fit.';
          note.textContent = 'Matched to your bedrooms and preferred pocket of Brisbane.';
        } else {
          heading.textContent = 'Nothing exact — yet.';
          note.textContent = 'None of our current releases match every answer, but new residences are always in design. Here is the full current collection — and we’ll flag upcoming releases that fit.';
        }

        detailsHeading.textContent = 'Where shall we send your matches?';
        submit.innerHTML = 'Send My Matches &rarr;';
        formNote.textContent = 'One of our team will be in touch within one business day.';
        enquiryType.value = 'Guided Match';
        shown = matched.length;
      }

      // serialise the questionnaire into the lead message
      msgField.value =
        (belowFloor ? 'Future-releases registration' : 'Guided match enquiry') + '\n' +
        'Timeline: ' + (answers.timeline || '-') + '\n' +
        'Construction flexibility: ' + (answers.flexibility || '-') + '\n' +
        'Bedrooms: ' + (answers.bedrooms || '-') + '\n' +
        'Maximum budget: ' + (answers.budget || '-') + '\n' +
        'Preferred area: ' + (answers.area || '-') + '\n' +
        (belowFloor
          ? 'Below threshold — no residences shown; registered for future releases.'
          : 'Matches shown: ' + (shown || 'none (full collection shown)'));
    }

    // fold the free-text notes into the message on submit
    form.addEventListener('submit', function () {
      var notes = form.querySelector('#fyh-notes');
      if (notes && notes.value.trim()) msgField.value += '\nNotes: ' + notes.value.trim();
    });
  });
  </script>
</Base>
