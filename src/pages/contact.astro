---
import Base from '../layouts/Base.astro';
import CustomSections from '../components/CustomSections.astro';
import { getProperties } from '../lib/db.js';
import { getContent } from '../lib/content.js';

const [{ settings, contact_page: page }, all] = await Promise.all([
  getContent('settings', 'contact_page'),
  getProperties(),
]);
const forSale = all.filter((p) => p.data.status === 'for-sale');
const socials = settings.socials;
---
<Base
  title="Contact | Sabdia Constructions"
  description="Get in touch with Sabdia Constructions. Brisbane's leading boutique luxury home builder and developer. Enquire about properties, custom builds, or development partnerships."
  lightNav
>
  <style is:inline slot="head">
  .contact-page-grid{display:grid;grid-template-columns:5fr 7fr;gap:96px;align-items:start}
  .contact-info-block{padding:44px;background:var(--dark);color:var(--white);margin-top:44px}
  .contact-info-h{font-family:var(--font-d);font-size:18px;font-weight:300;color:var(--white);margin-bottom:20px}
  .contact-social-row{display:flex;gap:10px;margin-top:28px}
  .contact-map-placeholder{width:100%;aspect-ratio:16/9;background:var(--bg3);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;margin-top:44px;position:relative;overflow:hidden}
  .contact-map-placeholder img{width:100%;height:100%;object-fit:cover;filter:saturate(.75) brightness(.98)}
  .contact-map-placeholder-label{position:absolute;bottom:20px;left:20px;padding:8px 16px;background:rgba(31,27,20,.8);backdrop-filter:blur(8px);font-size:10px;font-weight:300;letter-spacing:.22em;text-transform:uppercase;color:rgba(253,251,246,.7)}
  @media(max-width:1000px){.contact-page-grid{grid-template-columns:1fr;gap:52px}}
  .quick-links-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
  @media(max-width:900px){.quick-links-grid{grid-template-columns:1fr}}
  </style>

  <!-- HERO — warm stone rather than a black slab. This is the page that
       has to feel most like an invitation, and it carries no photograph
       to justify a dark treatment. -->
  <section style="padding:clamp(140px,20vw,200px) clamp(22px,5vw,80px) clamp(52px,8vw,96px);background:var(--bg3);border-bottom:1px solid var(--border)">
    <div class="inner">
      <div class="slabel reveal" style="margin-bottom:20px">{page.hero.label}</div>
      <h1 class="reveal d1" style="font-family:var(--font-d);font-size:clamp(52px,10vw,140px);font-weight:300;line-height:.9;letter-spacing:-.035em;color:var(--ink)" set:html={page.hero.titleHtml} />
      <p class="reveal d2" style="font-size:15.5px;font-weight:400;color:var(--ink3);max-width:460px;margin-top:28px;line-height:1.85">{page.hero.text}</p>
    </div>
  </section>

  <CustomSections page="/contact/" position="top" />

  <!-- CONTACT BODY -->
  <section class="sp">
    <div class="inner contact-page-grid">
      <!-- LEFT: Info -->
      <div>
        <div class="slabel reveal">{page.directLabel}</div>
        <ul class="cdet reveal d1" style="margin-top:12px">
          <li class="cd"><span class="cd-l">Location</span><span class="cd-v">{settings.location}</span></li>
          <li class="cd"><span class="cd-l">Instagram</span><a href={socials.instagram.url} target="_blank" class="cd-v">{socials.instagram.label}</a></li>
          <li class="cd"><span class="cd-l">Facebook</span><a href={socials.facebook.url} target="_blank" class="cd-v">{socials.facebook.label}</a></li>
          <li class="cd"><span class="cd-l">LinkedIn</span><a href={socials.linkedin.url} target="_blank" class="cd-v">{socials.linkedin.label}</a></li>
          <li class="cd"><span class="cd-l">Website</span><a href={settings.domainUrl} target="_blank" class="cd-v">{settings.domainDisplay}</a></li>
        </ul>

        <div class="contact-info-block reveal d2">
          <div class="contact-info-h">{page.agentBlock.heading}</div>
          <p style="font-size:14px;font-weight:400;color:rgba(253,251,246,.78);line-height:1.8" set:html={page.agentBlock.bodyHtml} />
        </div>

        <div class="contact-map-placeholder reveal d3" style="margin-top:32px">
          <img src={page.map.image} alt={page.map.label}>
          <div class="contact-map-placeholder-label">{page.map.label}</div>
        </div>
      </div>

      <!-- RIGHT: Form -->
      <div>
        <div class="slabel reveal">{page.form.label}</div>
        <p class="reveal d1" style="font-family:'EB Garamond',Georgia,serif;font-size:14px;font-style:italic;color:var(--ink3);margin:10px 0 6px">
          Looking to buy? Try our <a href="/find-your-home/" style="color:var(--ink);border-bottom:1px solid rgba(41,35,25,.45)">guided residence match</a> — five questions, tailored suggestions.
        </p>
        <form class="cform reveal d1" id="cform" style="margin-top:12px" name="contact" method="POST" action="/api/contact">
          <input type="hidden" name="form-name" value="contact">
          <p class="hidden" style="display:none" aria-hidden="true"><label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off"></label></p>
          <div class="frow">
            <div class="fg"><label class="fl" for="cf-first">First Name*</label><input type="text" id="cf-first" name="first-name" class="fi" placeholder="First name" autocomplete="given-name" required></div>
            <div class="fg"><label class="fl" for="cf-last">Last Name*</label><input type="text" id="cf-last" name="last-name" class="fi" placeholder="Last name" autocomplete="family-name" required></div>
          </div>
          <div class="fg"><label class="fl" for="cf-email">Email Address*</label><input type="email" id="cf-email" name="email" class="fi" placeholder="your@email.com" autocomplete="email" required></div>
          <div class="fg"><label class="fl" for="cf-phone">Phone Number</label><input type="tel" id="cf-phone" name="phone" class="fi" placeholder="+61 4xx xxx xxx" autocomplete="tel"></div>
          <div class="fg">
            <label class="fl" for="cf-interest">How can we help?*</label>
            <select class="fsel" id="cf-interest" name="enquiry-type" required>
              <option value="">Select an enquiry type…</option>
              <option>For Sale — Current Properties</option>
              {forSale.map((p) => <option>{p.data.name} — {p.data.suburb}</option>)}
              {page.form.interests.map((opt) => <option>{opt}</option>)}
            </select>
          </div>
          <div class="fg"><label class="fl" for="cf-message">Your Message*</label><textarea class="fta" id="cf-message" name="message" placeholder="Tell us about your interest, timeline, or any questions you have…" style="min-height:140px" required></textarea></div>
          <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap">
            <button type="submit" class="fsub" id="fsub">{page.form.submitLabel} &rarr;</button>
            <p class="form-note" style="margin:0">{page.form.note}</p>
          </div>
          <p class="sr-status" role="status" aria-live="polite" data-form-status></p>
        </form>
      </div>
    </div>
  </section>

  <!-- QUICK LINKS -->
  <section class="sp-sm" style="background:var(--bg2);border-top:1px solid var(--border)">
    <div class="inner">
      <div class="slabel reveal" style="margin-bottom:32px">{page.quickLinks.label}</div>
      <div class="quick-links-grid">
        {page.quickLinks.items.map((l, i) => (
          <a href={l.href} class={`reveal ${['', 'd1', 'd2'][i % 3]}`.trim()} style="display:block;padding:32px;background:var(--white);border:1px solid var(--border);transition:border-color .3s;text-decoration:none">
            <div style="font-size:10px;font-weight:500;letter-spacing:.26em;text-transform:uppercase;color:var(--ink);margin-bottom:10px">{l.tag}</div>
            <div style="font-family:var(--font-d);font-size:22px;font-weight:300;color:var(--ink);margin-bottom:8px">{l.title}</div>
            <div style="font-size:12px;font-weight:300;color:var(--ink3)">{l.desc}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CustomSections page="/contact/" position="end" />
</Base>
