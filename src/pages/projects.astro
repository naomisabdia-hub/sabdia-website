---
import Base from '../layouts/Base.astro';
import CustomSections from '../components/CustomSections.astro';
import JourneySlider from '../components/JourneySlider.astro';
import { imgVariant, landLabel } from '../lib/images.js';
import { getProperties } from '../lib/db.js';
import { getContent } from '../lib/content.js';

const [{ projects_page: page, home_stats: stats }, all] = await Promise.all([
  getContent('projects_page', 'home_stats'),
  getProperties(),
]);
const forSale = all.filter((p) => p.data.status === 'for-sale');
const sold = all.filter((p) => p.data.status === 'sold');

const specsLine = (d) => [`${d.beds} Bed`, `${d.baths} Bath`, `${d.cars} Garage`, landLabel(d.land, d.landOver)].join(' · ');

/* ── CONSTRUCTION JOURNEY DATA ──────────────────────────────────────────
   Two sample projects for the JourneySlider. The stage `image` values are
   PLACEHOLDERS — they currently reuse finished-home photography from the
   property galleries. To go live with real journeys:
     1. Replace each stage's `image` with an actual progress photo
        (same camera position per stage reads like a time-lapse).
     2. Rewrite the captions to describe what actually happened on site.
     3. `forSale: true` switches on the finale gallery + listing CTA;
        use `forSale: false` for past-build showcases.
   Long-term these belong in Supabase alongside the property rows —
   say the word and the schema/admin form can be added. */
const bySlug = Object.fromEntries(all.map((e) => [e.id, e]));
const journeyStage = (slug, gi, w = 1600, h = 1000) => {
  const e = bySlug[slug];
  const g = e?.data.gallery?.[gi];
  return g ? g.src : imgVariant(e.data.image, { w, h, focus: e.data.focus });
};

const journeys = [
  {
    // FOR-SALE example — full journey ending in the listing finale.
    // `video` switches on scrub mode: dragging the timeline scrubs this
    // AI-generated build time-lapse (Seedance via Higgsfield, end frame
    // anchored to the real QASR facade photo) hosted in Supabase storage.
    name: 'QASR',
    suburb: 'Coorparoo',
    forSale: true,
    listingHref: '/properties/qasr/',
    video: 'https://fvczsjcrvwzqtcbforgo.supabase.co/storage/v1/object/public/media/films/qasr-journey.mp4',
    poster: 'https://fvczsjcrvwzqtcbforgo.supabase.co/storage/v1/object/public/media/films/qasr-journey-poster.jpg',
    gallery: bySlug.qasr?.data.gallery ?? [],
    stages: [
      { label: 'Site & Foundation', caption: 'Every build begins with the land — engineered footings anchor QASR to its Coorparoo ridge.', image: journeyStage('qasr', 3) },
      { label: 'Frame',             caption: 'The structural skeleton rises, defining double-height voids and arched openings.', image: journeyStage('qasr', 1) },
      { label: 'Lock-up',           caption: 'Sealed to the weather, the facade takes on its Mediterranean rhythm.', image: journeyStage('qasr', 2) },
      { label: 'Fit-out',           caption: 'Travertine, brass and European oak — the interiors take their final form.', image: journeyStage('qasr', 4) },
      { label: 'Completed',         caption: 'A Mediterranean-inspired landmark, ready for its first owners.', image: journeyStage('qasr', 0) },
    ],
  },
  {
    // PAST-BUILD example — showcase mode, no finale panel.
    name: 'CAPRI',
    suburb: 'Hendra',
    forSale: false,
    listingHref: '/properties/capri/',
    gallery: [],
    stages: [
      { label: 'Site & Foundation', caption: 'From a quiet Hendra street, the site is cut, retained and made ready.', image: journeyStage('capri', 3) },
      { label: 'Frame',             caption: 'Steel and timber define the sculpted form to come.', image: journeyStage('capri', 1) },
      { label: 'Lock-up',           caption: 'Closed to the weather, the render and soft curves emerge.', image: journeyStage('capri', 2) },
      { label: 'Fit-out',           caption: 'Stone, oak and light — interiors layered by hand.', image: journeyStage('capri', 4) },
      { label: 'Completed',         caption: 'Sold prior to completion — a Hendra residence delivered in full.', image: journeyStage('capri', 0) },
    ],
  },
];
---
<Base
  preloadImage={imgVariant(page.hero.image, { w: 1920, h: 1080 })}
  title="Projects | Sabdia Constructions"
  description="Browse Sabdia Constructions' portfolio of completed luxury residential developments across inner Brisbane. 100+ residences since 2013."
>
  <style is:inline slot="head">
  .pfilter{font-size:11px;font-weight:400;letter-spacing:.16em;text-transform:uppercase;color:var(--taupe-d);transition:color .3s;background:none;border:none;cursor:pointer;padding:0 0 1px;border-bottom:1px solid transparent;font-family:var(--font-u)}
  .pfilter:hover{color:var(--ink)}
  .pfilter.on{color:var(--ink);border-bottom-color:var(--ink)}
  </style>

  <!-- HERO -->
  <section class="page-hero">
    <img src={imgVariant(page.hero.image, { w: 1920, h: 1080 })} alt="Projects" loading="eager" width="1920" height="1080">
    <div class="page-hero-ov"></div>
    <div class="page-hero-content inner">
      <div class="slabel slabel-dark">{page.hero.label}</div>
      <h1 class="page-h" set:html={page.hero.titleHtml} />
      <p class="page-hero-sub">{page.hero.sub}</p>
    </div>
  </section>

  <!-- FILTER BAR -->
  <div style="background:var(--bg2);border-bottom:1px solid var(--border);padding:20px clamp(22px,5vw,80px)">
    <div class="inner" style="display:flex;gap:20px;align-items:center;flex-wrap:wrap">
      <span style="font-size:10px;font-weight:500;letter-spacing:.26em;text-transform:uppercase;color:var(--taupe-d)">Filter:</span>
      <button class="pfilter on" data-filter="all">All</button>
      <button class="pfilter" data-filter="current">Current</button>
      <button class="pfilter" data-filter="sold">Sold</button>
    </div>
  </div>

  <CustomSections page="/projects/" position="top" />

  <!-- CURRENT PROPERTIES -->
  <section class="sp" data-proj-section="current">
    <div class="inner">
      <div class="slabel reveal" style="margin-bottom:32px">{page.currentLabel}</div>
      <div class="projects-grid">
        {forSale.map((p, i) => (
          <a href={`/properties/${p.id}/`} class={`proj-card reveal ${i % 2 === 1 ? 'd1' : ''}`}>
            <img src={imgVariant(p.data.image, { w: 1200, h: 750, focus: p.data.focus })} alt={p.data.name} loading="lazy">
            <div class="proj-card-ov"></div>
            <div class="proj-card-info">
              <div class="proj-card-year">{p.data.year} · For Sale</div>
              <div class="proj-card-name">{p.data.name}</div>
              <div class="proj-card-loc">{p.data.suburb}, QLD — {specsLine(p.data)}</div>
            </div>
            <div class="pc-arrow">&rarr;</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- SOLD PRIOR -->
  <section class="sp-sm" style="background:var(--bg2);border-top:1px solid var(--border)" data-proj-section="sold">
    <div class="inner">
      <div class="slabel reveal" style="margin-bottom:32px">{page.soldLabel}</div>
      <div class="projects-grid">
        {sold.map((p, i) => (
          <a href={`/properties/${p.id}/`} class={`proj-card reveal ${i % 2 === 1 ? 'd1' : ''}`}>
            <img src={imgVariant(p.data.image, { w: 1200, h: 750, focus: p.data.focus, q: 85 })} alt={p.data.name} loading="lazy">
            <div class="proj-card-ov"></div>
            <div class="sc-badge">Sold Prior to Completion</div>
            <div class="proj-card-info">
              <div class="proj-card-year">{p.data.year} · Sold</div>
              <div class="proj-card-name">{p.data.name}</div>
              <div class="proj-card-loc">{p.data.suburb}, QLD — {specsLine(p.data)}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CONSTRUCTION JOURNEY -->
  <section class="sp" id="journey" style="border-top:1px solid var(--border)">
    <div class="inner">
      <div class="slabel reveal">The Journey</div>
      <h2 class="about-h reveal d1" style="margin-bottom:8px">Watch a residence <em>take shape</em>.</h2>
      <p class="reveal d2" style="font-size:15px;font-weight:300;line-height:1.85;color:var(--ink3);max-width:520px;font-family:'EB Garamond',Georgia,serif">
        Every Sabdia home passes through five acts — drag the timeline to move through a build,
        or skip straight to the finished residence.
      </p>
      {journeys.map((j) => (
        <JourneySlider project={j} />
      ))}
    </div>
  </section>

  <!-- STATS BAND -->
  <div class="stats-band sp-sm">
    <div class="stats-grid inner">
      {stats.items.map((s, i) => (
        <div class={`stat reveal ${['', 'd1', 'd2', 'd3'][i % 4]}`.trim()}>
          <span class="stat-n">
            {s.count
              ? <span class="counter" data-target={s.target}>{s.target}</span>
              : s.target}<span class="stat-u">{s.suffix}</span>
          </span>
          <div class="stat-l">{s.label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- CTA -->
  <section class="sp" style="text-align:center">
    <div class="inner-sm">
      <div class="slabel reveal" style="justify-content:center;margin-bottom:20px">{page.cta.label}</div>
      <h2 class="about-h reveal d1" style="text-align:center;font-size:clamp(32px,5vw,60px)" set:html={page.cta.headingHtml} />
      <div class="reveal d2" style="display:flex;gap:14px;justify-content:center;margin-top:36px;flex-wrap:wrap">
        <a href={page.cta.primaryCta.href} class="btn-p">{page.cta.primaryCta.label}</a>
        <a href={page.cta.secondaryCta.href} class="btn-g">{page.cta.secondaryCta.label}</a>
      </div>
    </div>
  </section>

  <CustomSections page="/projects/" position="end" />

  <script is:inline>
  /* Re-runs per navigation — see main.js for why. Also called immediately:
     during a ClientRouter swap this script can execute after that
     navigation's page-load event already fired. */
  function sabdiaProjFilterInit() {
    var buttons = document.querySelectorAll('.pfilter');
    var sections = document.querySelectorAll('[data-proj-section]');
    if (!buttons.length || buttons[0].dataset.filterInit) return;
    buttons[0].dataset.filterInit = '1';
    buttons.forEach(function (btn) {
      btn.addEventListener('click', function () {
        buttons.forEach(function (b) { b.classList.remove('on'); });
        btn.classList.add('on');
        var f = btn.dataset.filter;
        sections.forEach(function (sec) {
          sec.style.display = f === 'all' || sec.dataset.projSection === f ? '' : 'none';
        });
      });
    });
  }
  sabdiaProjFilterInit();
  document.addEventListener('astro:page-load', sabdiaProjFilterInit);
  </script>
</Base>
