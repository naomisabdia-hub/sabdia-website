---
import Base from '../layouts/Base.astro';
import CustomSections from '../components/CustomSections.astro';
import { getContent, getServices, getProcessSteps } from '../lib/content.js';
import { imgVariant } from '../lib/images.js';

const [{ services_page: page }, services, processSteps] = await Promise.all([
  getContent('services_page'),
  getServices(),
  getProcessSteps(),
]);
---
<Base
  title="Services | Sabdia Constructions"
  description="Full-spectrum luxury residential development services — design, development management, interior architecture, and expert construction by Sabdia Constructions, Brisbane."
  ogTitle="Services — Sabdia Constructions"
  ogDescription={page.hero.sub}
  ogImage="/api/img?src=%2Fimages%2Fhome-hero-2.jpg&w=1200&h=630"
>
  <style is:inline slot="head">
  .svc-detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:96px;align-items:center;padding:clamp(72px,10vw,140px) 0}
  .svc-detail-grid:nth-child(even){direction:rtl}
  .svc-detail-grid:nth-child(even)>*{direction:ltr}
  .svc-detail-grid+.svc-detail-grid{border-top:1px solid var(--border)}
  .svc-detail-img{overflow:hidden;aspect-ratio:4/3}
  .svc-detail-img img{width:100%;height:100%;object-fit:cover;filter:saturate(.85);transition:transform .8s var(--ease)}
  .svc-detail-grid:hover .svc-detail-img img{transform:scale(1.04)}
  .svc-num{font-family:var(--font-d);font-size:clamp(80px,12vw,160px);font-weight:300;font-style:italic;color:rgba(180,155,90,.1);line-height:1;margin-bottom:-20px;display:block}
  .svc-detail-h{font-family:var(--font-d);font-size:clamp(30px,4vw,52px);font-weight:300;color:var(--ink);margin-bottom:20px;letter-spacing:-.02em}
  .svc-detail-h em{font-style:italic;color:var(--ink)}
  .svc-detail-p{font-size:13.5px;font-weight:300;line-height:1.9;color:var(--ink3);margin-bottom:16px}
  .svc-detail-list{list-style:none;margin-top:24px;border-top:1px solid var(--border);padding-top:24px}
  .svc-detail-list li{font-size:13px;font-weight:300;color:var(--ink3);padding:8px 0;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:12px}
  .svc-detail-list li::before{content:'';width:4px;height:4px;border-radius:50%;background:var(--gold);flex-shrink:0}
  @media(max-width:900px){.svc-detail-grid{grid-template-columns:1fr;gap:36px}.svc-detail-grid:nth-child(even){direction:ltr}}
  .svc-intro-grid{display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:center}
  @media(max-width:900px){.svc-intro-grid{grid-template-columns:1fr;gap:32px}}
  </style>

  <!-- HERO -->
  <section class="page-hero">
    <img src={imgVariant(page.hero.image, { w: 1920, h: 1080 })} alt="Services" loading="eager" width="1920" height="1080">
    <div class="page-hero-ov"></div>
    <div class="page-hero-content inner">
      <div class="slabel slabel-dark">{page.hero.label}</div>
      <h1 class="page-h" set:html={page.hero.titleHtml} />
      <p class="page-hero-sub">{page.hero.sub}</p>
    </div>
  </section>

  <CustomSections page="/services/" position="top" />

  <!-- INTRO -->
  <section class="sp-sm" style="border-bottom:1px solid var(--border)">
    <div class="inner svc-intro-grid">
      <div>
        <div class="slabel reveal">{page.intro.label}</div>
        <h2 class="about-h reveal d1" style="font-size:clamp(32px,4vw,52px)" set:html={page.intro.headingHtml} />
      </div>
      <div>
        {page.intro.paragraphs.map((p) => (
          <p class="about-p reveal d2">{p}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICE DETAILS -->
  <section class="sp">
    <div class="inner">
      {services.map((s, i) => (
        <div class="svc-detail-grid">
          <div class={`svc-detail-img ${i % 2 === 0 ? 'reveal-x' : 'reveal-r'}`}>
            <img src={imgVariant(s.detail.image, { w: 1200, h: 906 })} alt={s.detail.alt || s.title} loading="lazy" width="1200" height="906">
          </div>
          <div class="reveal">
            <span class="svc-num">{s.number}</span>
            <div class="slabel">{s.label}</div>
            <h2 class="svc-detail-h" set:html={s.detail.headingHtml} />
            {(s.detail.paragraphs || []).map((p) => (
              <p class="svc-detail-p">{p}</p>
            ))}
            <ul class="svc-detail-list">
              {(s.detail.bullets || []).map((b) => (
                <li>{b}</li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- PROCESS RECAP -->
  <section class="sp" style="background:var(--bg2);border-top:1px solid var(--border)">
    <div class="inner">
      <div class="slabel reveal" style="margin-bottom:56px">{page.processLabel}</div>
      <div class="proc-track">
        {processSteps.map((step, i) => (
          <div class={`proc-step reveal ${['', 'd1', 'd2', 'd3'][i % 4]}`.trim()}>
            <div class="proc-n">{i + 1}</div>
            <div class="proc-t">{step.title}</div>
            <div class="proc-d">{step.description}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="sp" style="background:var(--dark)">
    <div class="inner" style="text-align:center">
      <div class="slabel slabel-dark reveal" style="justify-content:center;margin-bottom:20px">{page.cta.label}</div>
      <h2 class="reveal d1" style="font-family:var(--font-d);font-size:clamp(36px,5vw,68px);font-weight:300;color:var(--white);margin-bottom:24px;letter-spacing:-.02em" set:html={page.cta.headingHtml} />
      <p class="reveal d2" style="font-size:13px;font-weight:300;color:rgba(253,251,246,.45);max-width:440px;margin:0 auto 40px;line-height:1.8">{page.cta.text}</p>
      <div class="reveal d3" style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
        <a href={page.cta.primaryCta.href} class="btn-p">{page.cta.primaryCta.label}</a>
        <a href={page.cta.secondaryCta.href} class="btn-g btn-g-light">{page.cta.secondaryCta.label}</a>
      </div>
    </div>
  </section>

  <CustomSections page="/services/" position="end" />
</Base>
