---
import AdminShell from '../../layouts/AdminShell.astro';
export const prerender = true;
---
<AdminShell title="Leads Inbox" active="leads">
  <div class="ad-hdr">
    <div>
      <h1 class="ad-h1">Leads <em>Inbox</em></h1>
      <p class="ad-sub">Every enquiry from every form on the website, broken down by where it came from. Update statuses as you work through them, reply without leaving the inbox, correct a lead's details, or delete what you don't need.</p>
    </div>
    <button class="ad-btn ad-btn-ghost" id="csvBtn">Export CSV</button>
  </div>

  <div class="ad-tabs" id="typeTabs"></div>

  <div class="ad-filters">
    <select class="ad-fsel" id="fStatus" style="max-width:180px">
      <option value="">All statuses</option>
      <option value="new">New</option>
      <option value="contacted">Contacted</option>
      <option value="closed">Closed</option>
    </select>
    <input class="ad-fi ad-search" id="fSearch" placeholder="Search name, email, property or agency…">
  </div>

  <div id="leadsBox"></div>
  <div class="ad-empty" id="leadsEmpty" style="display:none">No leads match.</div>
</AdminShell>

<script>
  import { supabase, requireAuth, accessToken, el, toast, csvExport, fmtDate } from '../../lib/admin/client.js';

  await requireAuth();

  const TYPES = [
    ['', 'All leads'],
    ['property-enquiry', 'Property enquiries'],
    ['contact', 'General contact'],
    ['agent-application', 'Agent applications'],
    ['guided-match', 'Guided matches'],
    ['newsletter', 'Newsletter signups'],
  ];

  let all = [];
  let activeType = '';

  const typeOf = (l) => l.form_name || 'contact';

  /* Sent replies per enquiry (see supabase/inbox-management.sql). If the
     replies table doesn't exist yet the inbox still works — the compose
     box shows, threads just can't be displayed. */
  let repliesBy = new Map();
  async function loadReplies() {
    const { data, error } = await supabase.from('replies').select('*').order('sent_at', { ascending: true });
    repliesBy = new Map();
    if (error) return console.warn('Reply history unavailable (run supabase/inbox-management.sql):', error.message);
    for (const r of data) {
      if (!repliesBy.has(r.enquiry_id)) repliesBy.set(r.enquiry_id, []);
      repliesBy.get(r.enquiry_id).push(r);
    }
  }

  async function load() {
    const [{ data, error }] = await Promise.all([
      supabase.from('enquiries').select('*').order('created_at', { ascending: false }),
      loadReplies(),
    ]);
    if (error) return toast(error.message, true);
    all = data;
    renderTabs();
    render();
  }

  function renderTabs() {
    const bar = document.getElementById('typeTabs');
    bar.innerHTML = '';
    for (const [value, label] of TYPES) {
      const rows = value ? all.filter((l) => typeOf(l) === value) : all;
      const fresh = rows.filter((l) => l.status === 'new').length;
      const btn = el('button', { type: 'button', class: `ad-tab${activeType === value ? ' on' : ''}` }, [
        el('span', { text: label }),
        el('span', { class: 'ad-tab-n', text: String(rows.length) }),
        fresh ? el('span', { class: 'ad-tab-new', text: `${fresh} new` }) : null,
      ].filter(Boolean));
      btn.addEventListener('click', () => { activeType = value; renderTabs(); render(); });
      bar.appendChild(btn);
    }
  }

  function matches(l) {
    if (activeType && typeOf(l) !== activeType) return false;
    const status = document.getElementById('fStatus').value;
    if (status && l.status !== status) return false;
    const q = document.getElementById('fSearch').value.toLowerCase();
    if (q) {
      const hay = `${l.first_name} ${l.last_name} ${l.email} ${l.agency} ${l.property}`.toLowerCase();
      if (!hay.includes(q)) return false;
    }
    return true;
  }

  function statusControl(l, badge) {
    const statusSel = el('select', { class: 'ad-fsel', style: 'max-width:160px' });
    for (const s of ['new', 'contacted', 'closed']) {
      const o = el('option', { value: s, text: s[0].toUpperCase() + s.slice(1) });
      if (l.status === s) o.selected = true;
      statusSel.appendChild(o);
    }
    statusSel.addEventListener('change', async () => {
      const { error } = await supabase.from('enquiries').update({ status: statusSel.value }).eq('id', l.id);
      if (error) return toast(error.message, true);
      l.status = statusSel.value;
      if (badge) { badge.className = 'ad-badge ' + l.status; badge.textContent = l.status; }
      renderTabs();
      toast('Status updated');
    });
    return statusSel;
  }

  function leadName(l) {
    return `${l.first_name ?? ''} ${l.last_name ?? ''}`.trim() || l.email || 'Anonymous';
  }

  /* Delete with an in-page two-step confirm — the first click arms the
     button for four seconds, the second actually deletes. */
  function deleteButton(l) {
    const btn = el('button', { class: 'ad-btn ad-btn-ghost', text: 'Delete', title: 'Delete this lead permanently', style: 'padding:8px 14px;font-size:10px' });
    let armed = false, timer;
    btn.addEventListener('click', async () => {
      if (!armed) {
        armed = true;
        btn.textContent = 'Confirm delete?';
        btn.classList.remove('ad-btn-ghost');
        btn.classList.add('ad-btn-danger');
        timer = setTimeout(() => { armed = false; btn.textContent = 'Delete'; btn.classList.add('ad-btn-ghost'); btn.classList.remove('ad-btn-danger'); }, 4000);
        return;
      }
      clearTimeout(timer);
      btn.disabled = true;
      /* .select() so a policy-blocked delete (0 rows, no error) is visible. */
      const { data, error } = await supabase.from('enquiries').delete().eq('id', l.id).select('id');
      if (error) { btn.disabled = false; return toast(error.message, true); }
      if (!data?.length) { btn.disabled = false; return toast('Delete was blocked by database permissions — run supabase/inbox-management.sql in the Supabase SQL editor first.', true); }
      all = all.filter((x) => x.id !== l.id);
      toast('Lead deleted');
      renderTabs();
      render();
    });
    return btn;
  }

  const EDIT_FIELDS = [
    ['first_name', 'First name'], ['last_name', 'Last name'], ['email', 'Email'], ['phone', 'Phone'],
    ['property', 'Property'], ['enquiry_type', 'Enquiry type'], ['agency', 'Agency'],
    ['licence_number', 'Licence no.'], ['suburb_markets', 'Suburb markets'],
  ];
  function editArea(l) {
    const inputs = {};
    const grid = el('div', { style: 'display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:10px 16px;margin:14px 0' },
      EDIT_FIELDS.map(([k, label]) => {
        inputs[k] = el('input', { class: 'ad-fi', value: l[k] ?? '' });
        return el('div', {}, [el('label', { class: 'ad-fl', text: label }), inputs[k]]);
      }));
    const msg = el('textarea', { class: 'ad-fta', text: l.message || '', style: 'min-height:80px' });
    const save = el('button', { class: 'ad-btn ad-btn-gold', text: 'Save changes' });
    const cancel = el('button', { class: 'ad-btn ad-btn-ghost', text: 'Cancel' });
    save.addEventListener('click', async () => {
      const patch = { message: msg.value.trim() || null };
      for (const [k] of EDIT_FIELDS) patch[k] = inputs[k].value.trim() || null;
      save.disabled = true;
      const { data, error } = await supabase.from('enquiries').update(patch).eq('id', l.id).select('id');
      save.disabled = false;
      if (error) return toast(error.message, true);
      if (!data?.length) return toast('Save was blocked by database permissions — check the enquiries update policy.', true);
      Object.assign(l, patch);
      toast('Lead updated');
      renderTabs();
      render();
    });
    cancel.addEventListener('click', () => { renderTabs(); render(); });
    return el('div', { style: 'border-top:1px solid var(--border);margin-top:14px;padding-top:4px;width:100%' }, [
      grid,
      el('div', { style: 'margin-bottom:12px' }, [el('label', { class: 'ad-fl', text: 'Message' }), msg]),
      el('div', { style: 'display:flex;gap:10px' }, [save, cancel]),
    ]);
  }

  function replyArea(l) {
    const wrap = el('div', { style: 'border-top:1px solid var(--border);margin-top:14px;padding-top:14px;width:100%' });
    const subject = el('input', { class: 'ad-fi', value: `Re: ${['Your enquiry', l.property].filter(Boolean).join(' — ')} | Sabdia Constructions` });
    const body = el('textarea', { class: 'ad-fta', placeholder: `Write your reply to ${leadName(l)} — it sends by email and is logged here…`, style: 'min-height:100px' });
    const send = el('button', { class: 'ad-btn ad-btn-gold', text: 'Send reply' });
    send.addEventListener('click', async () => {
      if (!body.value.trim()) return toast('Write a message first', true);
      send.disabled = true;
      send.textContent = 'Sending…';
      try {
        const token = await accessToken();
        const resp = await fetch('/api/reply', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + token },
          body: JSON.stringify({ enquiryId: l.id, subject: subject.value, body: body.value }),
        });
        const out = await resp.json();
        if (!resp.ok) throw new Error(out.error || 'The reply could not be sent.');
        toast(out.logged ? 'Reply sent' : 'Reply sent — but not logged; run supabase/inbox-management.sql');
        await loadReplies();
        renderTabs();
        render();
        return;
      } catch (e) {
        toast(e.message, true);
      }
      send.disabled = false;
      send.textContent = 'Send reply';
    });
    wrap.appendChild(el('div', { style: 'margin-bottom:10px' }, [el('label', { class: 'ad-fl', text: 'Subject' }), subject]));
    wrap.appendChild(el('div', { style: 'margin-bottom:12px' }, [body]));
    wrap.appendChild(send);
    return wrap;
  }

  function threadList(l) {
    const thread = repliesBy.get(l.id) || [];
    if (!thread.length) return null;
    return el('div', { style: 'width:100%;margin-top:12px;display:flex;flex-direction:column;gap:8px' },
      thread.map((r) => el('div', { style: 'background:var(--bg2);border-left:2px solid var(--gold);padding:10px 14px' }, [
        el('div', { text: `Replied ${fmtDate(r.sent_at)}${r.sent_by ? ' · ' + r.sent_by : ''} · ${r.subject}`, style: 'font-size:10.5px;color:var(--taupe-d);margin-bottom:4px' }),
        el('div', { text: r.body, style: 'font-size:12.5px;white-space:pre-wrap' }),
      ])));
  }

  /* Full card for contact / property / agent leads. */
  function leadCard(l, { hideProperty = false } = {}) {
    const details = [
      ['Email', l.email && el('a', { href: 'mailto:' + l.email, text: l.email, style: 'color:var(--gold)' })],
      ['Phone', l.phone && el('a', { href: 'tel:' + l.phone, text: l.phone, style: 'color:var(--gold)' })],
      ['Property', hideProperty ? null : l.property],
      ['Enquiry type', l.enquiry_type],
      ['Agency', l.agency],
      ['Licence no.', l.licence_number],
      ['Suburb markets', l.suburb_markets],
      ['Message', l.message],
      /* Catch-all details — every extra answer the visitor gave, verbatim. */
      ...Object.entries(l.details || {}).map(([k, v]) => [
        k.replace(/-/g, ' ').replace(/^./, (c) => c.toUpperCase()),
        String(v),
      ]),
    ].filter(([, v]) => v);

    const badge = el('span', { class: 'ad-badge ' + l.status, text: l.status });
    const statusSel = statusControl(l, badge);

    const notes = el('textarea', { class: 'ad-fta', placeholder: 'Internal notes…', text: l.notes || '', style: 'min-height:60px' });
    let notesTimer;
    notes.addEventListener('input', () => {
      clearTimeout(notesTimer);
      notesTimer = setTimeout(async () => {
        const { error } = await supabase.from('enquiries').update({ notes: notes.value }).eq('id', l.id);
        if (!error) toast('Notes saved');
      }, 900);
    });

    const typeLabel = { 'contact': 'Contact', 'property-enquiry': 'Property enquiry', 'agent-application': 'Agent application', 'guided-match': 'Guided match', 'newsletter': 'Newsletter' }[typeOf(l)] || l.form_name;

    /* Reply / Edit panels mount into this slot on demand; each button
       closes the other so only one panel is open per card. */
    const panel = el('div', { style: 'width:100%' });
    let openPanel = null;
    const togglePanel = (name, build) => {
      panel.innerHTML = '';
      if (openPanel === name) { openPanel = null; return; }
      openPanel = name;
      panel.appendChild(build());
    };
    const thread = repliesBy.get(l.id) || [];
    const replyBtn = l.email && el('button', { class: 'ad-btn ad-btn-ghost', text: thread.length ? `Reply (${thread.length})` : 'Reply', style: 'padding:8px 14px;font-size:10px', onclick: () => togglePanel('reply', () => replyArea(l)) });
    const editBtn = el('button', { class: 'ad-btn ad-btn-ghost', text: 'Edit', style: 'padding:8px 14px;font-size:10px', onclick: () => togglePanel('edit', () => editArea(l)) });

    return el('div', { class: 'ad-card' }, [
      el('div', { style: 'display:flex;align-items:center;gap:14px;flex-wrap:wrap;margin-bottom:12px' }, [
        el('strong', { text: leadName(l), style: 'font-weight:400;font-size:15px' }),
        badge,
        el('span', { text: typeLabel, style: 'font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--taupe-d)' }),
        el('span', { text: fmtDate(l.created_at), style: 'margin-left:auto;font-size:11px;color:var(--taupe-d)' }),
      ]),
      el('div', { style: 'display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:8px 20px;margin-bottom:14px' },
        details.map(([k, v]) => el('div', { style: 'font-size:12.5px' }, [
          el('span', { text: k + ': ', style: 'color:var(--taupe-d)' }),
          typeof v === 'string' ? el('span', { text: v }) : v,
        ])),
      ),
      el('div', { style: 'display:flex;gap:14px;align-items:flex-start;flex-wrap:wrap' }, [
        statusSel,
        notes,
        el('div', { style: 'display:flex;gap:8px;margin-left:auto' }, [replyBtn, editBtn, deleteButton(l)].filter(Boolean)),
      ]),
      threadList(l),
      panel,
    ]);
  }

  /* Compact row for newsletter signups — an address and a date, nothing more. */
  function newsletterRow(l) {
    const badge = el('span', { class: 'ad-badge ' + l.status, text: l.status });
    return el('div', { class: 'ad-card', style: 'display:flex;align-items:center;gap:14px;flex-wrap:wrap;padding:14px 18px' }, [
      el('a', { href: 'mailto:' + l.email, text: l.email, style: 'color:var(--gold);font-size:13.5px' }),
      badge,
      el('span', { text: fmtDate(l.created_at), style: 'font-size:11px;color:var(--taupe-d)' }),
      el('span', { style: 'margin-left:auto;display:flex;gap:8px;align-items:center' }, [statusControl(l, badge), deleteButton(l)]),
    ]);
  }

  function sectionHeading(text, count) {
    return el('div', { class: 'ad-lead-sec' }, [
      el('span', { text }),
      el('span', { class: 'ad-tab-n', text: String(count) }),
    ]);
  }

  function render() {
    const box = document.getElementById('leadsBox');
    box.innerHTML = '';
    const rows = all.filter(matches);
    document.getElementById('leadsEmpty').style.display = rows.length ? 'none' : '';

    if (activeType === 'property-enquiry') {
      /* Broken down further: one section per residence. */
      const byProperty = new Map();
      for (const l of rows) {
        const key = l.property || 'No property specified';
        if (!byProperty.has(key)) byProperty.set(key, []);
        byProperty.get(key).push(l);
      }
      for (const [property, leads] of [...byProperty.entries()].sort((a, b) => b[1].length - a[1].length)) {
        box.appendChild(sectionHeading(property, leads.length));
        for (const l of leads) box.appendChild(leadCard(l, { hideProperty: true }));
      }
      return;
    }

    if (activeType === 'newsletter') {
      for (const l of rows) box.appendChild(newsletterRow(l));
      return;
    }

    if (activeType === '') {
      /* The overview: every stream in its own section, newest first inside each. */
      const order = ['property-enquiry', 'guided-match', 'contact', 'agent-application', 'newsletter'];
      const labels = { 'property-enquiry': 'Property enquiries', 'guided-match': 'Guided matches', 'contact': 'General contact', 'agent-application': 'Agent applications', 'newsletter': 'Newsletter signups' };
      for (const t of order) {
        const leads = rows.filter((l) => typeOf(l) === t);
        if (!leads.length) continue;
        box.appendChild(sectionHeading(labels[t], leads.length));
        for (const l of leads) box.appendChild(t === 'newsletter' ? newsletterRow(l) : leadCard(l));
      }
      /* Anything with an unrecognised form name still shows. */
      const other = rows.filter((l) => !order.includes(typeOf(l)));
      if (other.length) {
        box.appendChild(sectionHeading('Other', other.length));
        for (const l of other) box.appendChild(leadCard(l));
      }
      return;
    }

    for (const l of rows) box.appendChild(leadCard(l));
  }

  for (const id of ['fStatus', 'fSearch']) {
    document.getElementById(id).addEventListener(id === 'fSearch' ? 'input' : 'change', render);
  }

  document.getElementById('csvBtn').addEventListener('click', () => {
    const rows = all.filter(matches).map((l) => ({
      received: l.created_at, type: l.form_name, status: l.status,
      first_name: l.first_name, last_name: l.last_name, email: l.email, phone: l.phone,
      property: l.property, enquiry_type: l.enquiry_type, agency: l.agency,
      licence_number: l.licence_number, suburb_markets: l.suburb_markets,
      message: l.message, notes: l.notes,
      ...(l.details || {}),
    }));
    csvExport(rows, activeType ? `sabdia-leads-${activeType}.csv` : 'sabdia-leads.csv');
  });

  await load();
</script>
