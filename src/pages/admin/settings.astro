---
import AdminShell from '../../layouts/AdminShell.astro';
export const prerender = true;
---
<AdminShell title="Settings" active="settings">
  <div class="ad-hdr">
    <div>
      <h1 class="ad-h1">Settings</h1>
      <p class="ad-sub">Company details, social links, search defaults, and portal users.</p>
    </div>
  </div>

  <div class="ad-form" id="settingsForm"></div>
  <div class="ad-savebar" id="saveBar">
    <button class="ad-btn ad-btn-gold" data-save>Save settings</button>
    <span class="ad-dirty">Unsaved changes</span>
  </div>

  <div class="ad-card" style="margin-top:28px" id="pwCard">
    <div class="ad-card-h">Your password</div>
    <p class="ad-sub" style="margin-bottom:16px">Set or change the password for your own sign-in. (You can always use the email-link option on the login page instead.)</p>
    <form class="ad-form" id="pwForm" style="max-width:380px">
      <div class="ad-fg">
        <label class="ad-fl" for="newPw">New password</label>
        <input class="ad-fi" type="password" id="newPw" autocomplete="new-password" minlength="8" required>
      </div>
      <button class="ad-btn" type="submit">Update password</button>
    </form>
  </div>

  <div class="ad-card" style="margin-top:28px" id="usersCard">
    <div class="ad-card-h">Team access</div>
    <p class="ad-sub" style="margin-bottom:16px" id="usersHelp">Who can sign in to this portal. <b>Editors</b> can change content and properties; <b>Admins</b> can also manage the team.</p>
    <table class="ad-table" id="usersTable">
      <thead><tr><th>Email</th><th>Role</th><th>Added</th><th></th></tr></thead>
      <tbody></tbody>
    </table>
    <form class="ad-form" id="addUserForm" style="margin-top:18px;display:none">
      <div class="ad-frow3">
        <div class="ad-fg">
          <label class="ad-fl" for="nuEmail">Email</label>
          <input class="ad-fi" type="email" id="nuEmail" placeholder="teammate@sabdia.com.au" required>
        </div>
        <div class="ad-fg">
          <label class="ad-fl" for="nuRole">Role</label>
          <select class="ad-fsel" id="nuRole">
            <option value="editor">Editor</option>
            <option value="admin">Admin</option>
          </select>
        </div>
        <div class="ad-fg">
          <label class="ad-fl">&nbsp;</label>
          <button class="ad-btn ad-btn-gold" type="submit">Add team member</button>
        </div>
      </div>
    </form>
  </div>
</AdminShell>

<script>
  import { supabase, requireAuth, el, fmtDate, toast, clerkMode } from '../../lib/admin/client.js';
  import { buildForm, readForm, saveBar } from '../../lib/admin/forms.js';
  import { contentSchemas } from '../../lib/admin/schemas.js';
  import seed from '../../lib/seed-content.json';

  const me = await requireAuth();

  // Clerk manages passwords when it is active.
  if (clerkMode) document.getElementById('pwCard').style.display = 'none';

  const schema = contentSchemas.settings.schema;
  const { data } = await supabase.from('site_content').select('data').eq('key', 'settings').maybeSingle();
  let current = data?.data ?? seed.settings;
  buildForm(document.getElementById('settingsForm'), schema, current);

  saveBar(document.getElementById('settingsForm'), document.getElementById('saveBar'), async () => {
    current = readForm(document.getElementById('settingsForm'), schema, current);
    const { error } = await supabase.from('site_content').upsert({ key: 'settings', data: current });
    if (error) throw error;
  });

  document.getElementById('pwForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const { error } = await supabase.auth.updateUser({ password: document.getElementById('newPw').value });
    if (error) return toast(error.message, true);
    document.getElementById('newPw').value = '';
    toast('Password updated');
  });

  const isAdmin = me.role === 'admin';
  const addForm = document.getElementById('addUserForm');
  addForm.style.display = isAdmin ? '' : 'none';
  if (isAdmin) {
    document.getElementById('usersHelp').innerHTML +=
      clerkMode
        ? ' New teammates: add their email below, then they sign in at <b>/admin/login/</b> with that email.'
        : ' New teammates: add their email below, then they use “Email me a sign-in link” at <b>/admin/login/</b>.';
  }

  async function loadUsers() {
    const { data: users } = await supabase.from('admin_users').select('*').order('created_at');
    const tbody = document.querySelector('#usersTable tbody');
    tbody.innerHTML = '';
    for (const u of users ?? []) {
      tbody.appendChild(el('tr', {}, [
        el('td', { text: u.email }),
        el('td', { text: u.role }),
        el('td', { text: fmtDate(u.created_at) }),
        el('td', { style: 'text-align:right' }, [
          isAdmin && u.email !== me.user?.primaryEmailAddress?.emailAddress && u.email !== (me.user?.email ?? '')
            ? el('button', { class: 'ad-btn ad-btn-danger', text: 'Remove', style: 'padding:6px 14px', onclick: async () => {
                if (!confirm(`Remove ${u.email} from the portal? They will no longer be able to sign in.`)) return;
                const { error } = await supabase.from('admin_users').delete().eq('email', u.email);
                if (error) return toast(error.message, true);
                toast('Access removed');
                loadUsers();
              } })
            : null,
        ]),
      ]));
    }
  }

  addForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = document.getElementById('nuEmail').value.trim().toLowerCase();
    const role = document.getElementById('nuRole').value;
    const { error } = await supabase.from('admin_users').insert({ email, role });
    if (error) return toast(error.message.includes('policy') ? 'Could not add — run the team-access update (clerk-auth.sql) in Supabase first.' : error.message, true);
    toast(`${email} can now sign in`);
    document.getElementById('nuEmail').value = '';
    loadUsers();
  });

  await loadUsers();
</script>
