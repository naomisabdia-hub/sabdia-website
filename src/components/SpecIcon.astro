---
/* Line icons for property specs and locations. Sized in em so they
   scale with whatever label sits beside them, and drawn in currentColor
   so a chip only has to set one colour. Matches the weight of the
   existing ServiceIcon / BenefitIcon sets. */
const { icon } = Astro.props;
---
{icon === 'beds' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M3 18v-7a1 1 0 0 1 1-1h16a1 1 0 0 1 1 1v7" />
    <path d="M3 14h18" />
    <path d="M6 10V7a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v3" />
    <path d="M3 18v2M21 18v2" />
  </svg>
)}
{icon === 'baths' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M3 12h18v3a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4v-3Z" />
    <path d="M6 12V6.5A2.5 2.5 0 0 1 8.5 4a2.5 2.5 0 0 1 2.5 2.5" />
    <path d="M10 6.5h2" />
    <path d="M7 19l-1 2M17 19l1 2" />
  </svg>
)}
{icon === 'cars' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M4 16v-3.2a2 2 0 0 1 .14-.73l1.6-4A2 2 0 0 1 7.6 7h8.8a2 2 0 0 1 1.86 1.07l1.6 4a2 2 0 0 1 .14.73V16" />
    <path d="M4 16h16v2a1 1 0 0 1-1 1h-1a1 1 0 0 1-1-1v-1H7v1a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-2Z" />
    <path d="M7 13h1M16 13h1" />
  </svg>
)}
{icon === 'land' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M4 9V4h5M20 9V4h-5M4 15v5h5M20 15v5h-5" />
  </svg>
)}
{icon === 'pin' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 21s7-5.6 7-11a7 7 0 1 0-14 0c0 5.4 7 11 7 11Z" />
    <circle cx="12" cy="10" r="2.4" />
  </svg>
)}
