---
import { getProperties } from '../lib/db.js';
import { getContent } from '../lib/content.js';

const [{ settings, footer }, all] = await Promise.all([
  getContent('settings', 'footer'),
  getProperties(),
]);
const forSale = all.filter((p) => p.data.status === 'for-sale');
const socials = settings.socials;
const year = new Date().getFullYear();
---
<footer>
  <div class="footer-tagline">
    <div class="footer-tagline-inner">
      <h2 class="footer-tag-h" set:html={footer.taglineHtml} />
      <p class="footer-tag-sub">{footer.taglineSub}</p>
    </div>
  </div>
  <div class="fg-grid">
    <div>
      <a href="/" class="flogo" aria-label={settings.siteName}>
        <img src={settings.logo} alt={settings.siteName}>
      </a>
      <p class="ftag" set:html={footer.blurbHtml} />
      <div class="fsoc">
        <a href={socials.instagram.url} target="_blank" rel="noopener" class="fsl" aria-label="Instagram">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none"/></svg>
        </a>
        <a href={socials.facebook.url} target="_blank" rel="noopener" class="fsl" aria-label="Facebook">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href={socials.linkedin.url} target="_blank" rel="noopener" class="fsl" aria-label="LinkedIn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
      </div>
    </div>
    <div>
      <div class="fct">For Sale</div>
      <ul class="fcl">
        {forSale.map((p) => (
          <li><a href={`/properties/${p.id}/`}>{p.data.name} — {p.data.suburb}</a></li>
        ))}
        <li><a href="/properties/">View All Properties</a></li>
      </ul>
    </div>
    <div>
      <div class="fct">Company</div>
      <ul class="fcl">
        {footer.companyLinks.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </div>
    <div>
      <div class="fct">Connect</div>
      <ul class="fcl">
        <li><a href="/contact/">Contact Us</a></li>
        {settings.phone && <li><a href={`tel:${settings.phone.replace(/[^+\d]/g, '')}`}>{settings.phone}</a></li>}
        {settings.email && <li><a href={`mailto:${settings.email}`}>{settings.email}</a></li>}
        <li><a href={socials.instagram.url} target="_blank" rel="noopener">Instagram {socials.instagram.label}</a></li>
        <li><a href={socials.facebook.url} target="_blank" rel="noopener">Facebook</a></li>
        <li><a href={socials.linkedin.url} target="_blank" rel="noopener">LinkedIn</a></li>
        <li><a href={settings.domainUrl} target="_blank" rel="noopener">{settings.domainDisplay}</a></li>
      </ul>
    </div>
  </div>
  <div class="fbot">
    <div class="fcopy">&copy; {year} {settings.legalName}. All rights reserved.</div>
    <div class="flinks">
      {footer.legalLinks.map((l) => (
        <a href={l.href}>{l.label}</a>
      ))}
    </div>
  </div>
</footer>
