---
/**
 * Cinematic film section — a vertical reel in a framed player beside
 * editorial copy. Autoplays muted when scrolled into view (unless the
 * visitor prefers reduced motion); tap the control for sound.
 *
 * Props: label, headingHtml, text, video, poster, captionLeft, captionRight, id
 */
const { label, headingHtml, text, video, poster, captionLeft = '', captionRight = '', id = 'film' } = Astro.props;
---
{video && (
  <section class="film-band" id={id}>
    <div class="film-grid">
      <div class="film-copy">
        <div class="slabel slabel-dark reveal">{label}</div>
        <h2 class="film-h reveal d1" set:html={headingHtml} />
        {text && <p class="film-p reveal d2">{text}</p>}
        <slot />
      </div>
      <div class="reveal d2">
        <div class="film-frame" data-film>
          <video
            src={video}
            poster={poster || undefined}
            muted
            loop
            playsinline
            preload="none"
          ></video>
          <button class="film-sound" type="button" aria-label="Toggle sound" data-sound>
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" fill="currentColor"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
            <span data-sound-label>Sound On</span>
          </button>
        </div>
        {(captionLeft || captionRight) && (
          <div class="film-caption">
            <span><b>{captionLeft}</b></span>
            <span>{captionRight}</span>
          </div>
        )}
      </div>
    </div>
  </section>
)}

<script is:inline>
/* Re-runs per navigation — see main.js for why. The dataset.filmInit
   guard still prevents double-wiring within a single page.
   Called immediately as well as on astro:page-load: during a ClientRouter
   swap this script can be (re)parsed after that navigation's page-load
   event has already fired, so waiting on the event alone leaves the
   section dead until a manual refresh. */
function sabdiaFilmInit() {
  document.querySelectorAll('[data-film]').forEach(function (frame) {
    if (frame.dataset.filmInit) return;
    frame.dataset.filmInit = '1';
    var video = frame.querySelector('video');
    var btn = frame.querySelector('[data-sound]');
    var label = frame.querySelector('[data-sound-label]');
    var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if ('IntersectionObserver' in window && !reduced) {
      /* play() is one-shot and its rejection used to be swallowed — a
         transient refusal (power saving, data not buffered, occluded
         tab) left the film permanently frozen until a manual refresh.
         Now the intent ("should be playing") is tracked and re-attempted
         on canplay, on tab visibility, and on a short bounded retry. */
      var wantPlay = false;
      var retries = 0;
      var attempt = function () {
        if (!wantPlay || !video.isConnected || !video.paused) return;
        var p = video.play();
        if (p && p.catch) p.catch(function () {
          if (wantPlay && retries++ < 12) setTimeout(attempt, 700);
        });
      };
      video.addEventListener('canplay', attempt);
      document.addEventListener('visibilitychange', function () {
        if (!document.hidden) attempt();
      });
      /* Hysteresis: start once a third of the frame is visible, but only
         pause when it has fully left the viewport. A single threshold
         both ways let every layout nudge (late images reflowing the
         page) rapid-cycle play/pause — a visibly glitching film. */
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (en) {
          if (en.intersectionRatio >= 0.35) {
            wantPlay = true;
            retries = 0;
            attempt();
          } else if (!en.isIntersecting) {
            wantPlay = false;
            video.pause();
          }
        });
      }, { threshold: [0, 0.35] });
      io.observe(frame);
    }

    btn.addEventListener('click', function () {
      video.muted = !video.muted;
      if (!video.muted && video.paused) video.play().catch(function () {});
      label.textContent = video.muted ? 'Sound On' : 'Mute';
    });
  });
}
sabdiaFilmInit();
document.addEventListener('astro:page-load', sabdiaFilmInit);
</script>
