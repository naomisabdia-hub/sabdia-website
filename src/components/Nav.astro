---
import { getContent } from '../lib/content.js';

interface Props {
  /* Set on pages whose first section is a light surface rather than a
     photograph or a dark band. The nav renders white-on-transparent by
     default, which disappears entirely against cream. */
  lightNav?: boolean;
}
const { lightNav = false } = Astro.props;

const { settings, nav } = await getContent('settings', 'nav');
const socials = settings.socials;

/* The opening loader is a homepage-only gesture. It used to render inside
   every page (Nav sits in Base), so a full-screen cream overlay flashed on
   every single navigation — an interruption, not an overture. A repeat
   visit within the same session skips it too; see the head script in
   Base.astro, which sets html.no-loader before first paint. */
const isHome = Astro.url.pathname === '/';
---
<div id="cur" aria-hidden="true"></div>
<div id="cur-r" aria-hidden="true"></div>

<!-- Navigation progress. Sits above the nav and outside it, so it reads the
     same on a photographic hero as on a cream page, and is not tied to the
     nav's scrolled state the way the scroll-progress hairline is. -->
<div class="nav-load" id="navLoad" aria-hidden="true"></div>

{isHome && (
  <div id="loader" aria-hidden="true">
    <div class="ld-logo">
      <img src={settings.logoLarge} alt="" loading="eager">
    </div>
    <div class="ld-rule"></div>
    <div class="ld-meta">{nav.loaderMeta}</div>
  </div>
)}

<div class="mob-nav" id="mobNav" aria-hidden="true">
  <nav class="mob-nav-links" aria-label="Mobile">
    {nav.mobileItems.map((item) => (
      <a href={item.href}>{item.label}</a>
    ))}
  </nav>
  <div class="mob-nav-rule"></div>
  <div class="mob-nav-sub">
    <a href={socials.instagram.url} target="_blank" rel="noopener">Instagram</a>
    <a href={socials.facebook.url} target="_blank" rel="noopener">Facebook</a>
    <a href={socials.linkedin.url} target="_blank" rel="noopener">LinkedIn</a>
  </div>
</div>

<nav id="mainNav" class={lightNav ? 'on-light' : undefined} aria-label="Primary">
  <a href="/" class="nav-logo" aria-label={`${settings.siteName} — Home`}>
    <img class="logo-light" src={settings.logo} alt={`${settings.siteName} — Design Develop Construct`} style="filter:invert(1) brightness(10)">
    <img class="logo-dark" src={settings.logo} alt={`${settings.siteName} — Design Develop Construct`}>
  </a>
  <ul class="nav-center">
    {nav.items.map((item) => (
      <li><a href={item.href}>{item.label}</a></li>
    ))}
  </ul>
  <div class="nav-right">
    <a href={nav.cta.href} class="nav-cta">{nav.cta.label}</a>
    <button class="mob-btn" id="mobBtn" aria-label="Open menu" aria-expanded="false" aria-controls="mobNav"><span></span><span></span></button>
  </div>
  <div class="nav-progress" id="navProgress" aria-hidden="true"></div>
</nav>
