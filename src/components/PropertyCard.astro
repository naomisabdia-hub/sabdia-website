---
import { wixResize } from '../lib/wix.js';
import SpecIcon from './SpecIcon.astro';

const { entry, class: cls = '', style, imgW, imgH, specs = [] } = Astro.props;
const d = entry.data;

/* Callers pass specs as ready-made strings ("5 Bed", "1000m²+"), all of
   them produced by the same two helpers in lib/wix.js, so the icon can
   be inferred from the label rather than forcing every call site to
   switch to a structured shape. Anything unrecognised simply renders
   as a chip with no icon. */
const iconFor = (label) => {
  const s = String(label).toLowerCase();
  if (s.includes('bed')) return 'beds';
  if (s.includes('bath')) return 'baths';
  if (s.includes('garage') || s.includes('car')) return 'cars';
  if (s.includes('m²') || s.includes('sqm') || s.includes('land')) return 'land';
  return null;
};
---
<a href={`/properties/${entry.id}/`} class={`pc ${cls}`} style={style}>
  <img
    src={wixResize(d.image, { w: imgW, h: imgH, focus: d.focus })}
    srcset={`${wixResize(d.image, { w: imgW, h: imgH, focus: d.focus })} 1x, ${wixResize(d.image, { w: imgW * 2, h: imgH * 2, focus: d.focus, q: 75 })} 2x`}
    alt={d.name} loading="lazy" decoding="async" width={imgW} height={imgH}>
  <div class="pc-ov"></div>
  <div class="pc-status-chip"><span class="pc-dot"></span>For Sale</div>
  <div class="pc-info">
    <div class="pc-name">{d.name}</div>
    <div class="pc-loc"><SpecIcon icon="pin" />{d.suburb}, QLD</div>
    {specs.length > 0 && (
      <ul class="pc-specs">
        {specs.map((s) => {
          const ic = iconFor(s);
          return (
            <li class="pc-spec">
              {ic && <SpecIcon icon={ic} />}
              <span>{s}</span>
            </li>
          );
        })}
      </ul>
    )}
  </div>
  <div class="pc-arrow">&rarr;</div>
</a>
