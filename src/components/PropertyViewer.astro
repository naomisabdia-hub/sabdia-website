---
/**
 * Interactive 3D viewer for a property.
 *
 * Two source types, chosen per property in the admin:
 *   viewer_type = 'model' → GLB/GLTF rendered with <model-viewer>
 *                            (orbit, auto-rotate, AR, optional hotspots)
 *   viewer_type = 'tour'  → embedded Matterport / 360° tour iframe
 *   viewer_type = 'none'  → renders nothing (graceful degradation)
 *
 * The model-viewer library (~1MB, self-hosted) and the model itself are
 * lazy-loaded only when the section scrolls near the viewport, so they
 * never affect first paint. Auto-rotate is disabled when the visitor
 * prefers reduced motion.
 */
const { property } = Astro.props;
const d = property.data;
const mode = d.viewerType;
const show = (mode === 'model' && d.modelUrl) || (mode === 'tour' && d.tourUrl);
const hotspots = Array.isArray(d.hotspots) ? d.hotspots : [];
---
{show && (
  <section class="viewer-section inner" id="viewer">
    <div class="viewer-hdr">
      <div>
        <div class="slabel reveal">Explore in 3D</div>
        <h2 class="viewer-h reveal d1">Walk around <em>{d.name}</em>.</h2>
      </div>
      <p class="viewer-sub reveal d2">
        {mode === 'model'
          ? 'Drag to orbit, scroll to zoom — or view the residence in your own space on mobile.'
          : 'Step inside and move through the residence room by room.'}
      </p>
    </div>

    <div class="viewer-frame reveal" data-viewer={mode} data-model={mode === 'model' ? d.modelUrl : undefined}>
      {mode === 'model' ? (
        <div class="viewer-stage" id="viewerStage">
          {d.posterUrl && <img class="viewer-poster" src={d.posterUrl} alt={`3D model of ${d.name}`} loading="lazy">}
          <div class="viewer-hint" aria-hidden="true">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M12 2v20M2 12h20"/><path d="M7 7l10 10M17 7L7 17"/></svg>
            <span>Drag to explore</span>
          </div>
          <template id="viewerTpl">
            <model-viewer
              src={d.modelUrl}
              poster={d.posterUrl || undefined}
              alt={`Interactive 3D model of ${d.name}`}
              camera-controls
              touch-action="pan-y"
              shadow-intensity="1"
              shadow-softness="0.8"
              exposure="0.9"
              interaction-prompt="none"
              ar
              ar-modes="webxr scene-viewer quick-look"
              style="width:100%;height:100%;background:transparent"
            >
              {hotspots.map((h, i) => (
                <button
                  slot={`hotspot-${i}`}
                  class="viewer-hotspot"
                  data-position={h.position}
                  data-normal={h.normal || '0 1 0'}
                  data-visibility-attribute="visible"
                >
                  <span class="viewer-hotspot-dot"></span>
                  <span class="viewer-hotspot-label">{h.label}</span>
                </button>
              ))}
            </model-viewer>
          </template>
        </div>
      ) : (
        <div class="viewer-stage">
          <iframe
            class="viewer-tour"
            data-src={d.tourUrl}
            title={`Virtual tour of ${d.name}`}
            allow="xr-spatial-tracking; fullscreen"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      )}
      <div class="viewer-caption">
        <span class="viewer-caption-l">{d.name} — {mode === 'model' ? 'Interactive Model' : 'Virtual Tour'}</span>
        <span class="viewer-caption-r">{d.suburb}, {d.state}</span>
      </div>
    </div>
  </section>
)}

{show && (
  <script is:inline>
  (function () {
    var frame = document.querySelector('.viewer-frame');
    if (!frame) return;
    var loaded = false;
    function activate() {
      if (loaded) return;
      loaded = true;
      if (frame.dataset.viewer === 'model') {
        var boot = function () {
          var tpl = document.getElementById('viewerTpl');
          var stage = document.getElementById('viewerStage');
          if (!tpl || !stage) return;
          var mv = tpl.content.firstElementChild.cloneNode(true);
          var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          if (!reduced) {
            mv.setAttribute('auto-rotate', '');
            mv.setAttribute('auto-rotate-delay', '2500');
            mv.setAttribute('rotation-per-second', '18deg');
          }
          stage.appendChild(mv);
          if (mv.loaded) stage.classList.add('viewer-ready');
          else mv.addEventListener('load', function () { stage.classList.add('viewer-ready'); });
        };
        if (window.customElements && window.customElements.get('model-viewer')) {
          boot();
        } else {
          var s = document.createElement('script');
          s.type = 'module';
          s.src = '/js/vendor/model-viewer.min.js';
          s.onload = function () { customElements.whenDefined('model-viewer').then(boot); };
          document.head.appendChild(s);
        }
      } else {
        var tour = frame.querySelector('.viewer-tour');
        if (tour && !tour.src) tour.src = tour.dataset.src;
      }
    }
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (en) {
          if (en.isIntersecting) { activate(); io.disconnect(); }
        });
      }, { rootMargin: '600px 0px' });
      io.observe(frame);
    } else {
      activate();
    }
  })();
  </script>
)}
