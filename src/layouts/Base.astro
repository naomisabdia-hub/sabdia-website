---
import { ClientRouter } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  preloadImage?: string;
  preloadImageSet?: string;
  preloadImageSizes?: string;
  /* Optional media query gating the preload (e.g. desktop-only hero crop). */
  preloadImageMedia?: string;
  /* Pass on pages that open on a light surface instead of a photograph
     or dark band, so the nav renders dark-on-light from the top. */
  lightNav?: boolean;
}

const { title, description, ogTitle, ogDescription, ogImage, preloadImage, preloadImageSet, preloadImageSizes, preloadImageMedia, lightNav } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
/* Every page ships a complete share card: pages may override any part,
   but nothing renders bare when shared. Crawlers need og:image absolute;
   pages pass site-relative paths. */
const ogT = ogTitle ?? title;
const ogD = ogDescription ?? description;
const OG_DEFAULT = '/api/img?src=%2Fimages%2Fhome-hero-1.jpg&w=1200&h=630&q=85';
const ogImageAbs = new URL(ogImage ?? OG_DEFAULT, Astro.site).href;
const gaId = import.meta.env.PUBLIC_GA4_ID;
/* Deploy-stamped asset URLs. Without a version, a visitor's browser can
   keep serving its cached main.js/style.css across deploys — fixes ship
   but never reach them until a manual hard refresh. The commit sha makes
   each deploy a new URL; main.js's own init guard makes a mid-session
   re-execution (head swap after a deploy) harmless. */
const assetV = (import.meta.env.VERCEL_GIT_COMMIT_SHA ?? process.env.VERCEL_GIT_COMMIT_SHA ?? '').slice(0, 8);
const withV = (p) => (assetV ? `${p}?v=${assetV}` : p);
---
<!DOCTYPE html>
<html lang="en-AU">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="theme-color" content="#F7F3EB">
<title>{title}</title>
<meta name="description" content={description}>
<link rel="canonical" href={canonical}>
<link rel="icon" type="image/png" sizes="32x32" href={withV('/favicon-32.png')}>
<link rel="icon" type="image/png" sizes="16x16" href={withV('/favicon-16.png')}>
<link rel="apple-touch-icon" href={withV('/apple-touch-icon.png')}>
<script is:inline>
document.documentElement.classList.add('js');
/* Runs before first paint so the loader never flashes on a repeat visit.
   sessionStorage, not localStorage: the opening is worth seeing once per
   visit, not once per lifetime. Wrapped because Safari private mode throws
   on storage access — a failure here just means the loader plays. */
try {
  if (sessionStorage.getItem('sabdia:seen')) document.documentElement.classList.add('no-loader');
  else sessionStorage.setItem('sabdia:seen', '1');
} catch (e) {}
</script>
<meta property="og:title" content={ogT}>
<meta property="og:description" content={ogD}>
<meta property="og:type" content="website">
<meta property="og:url" content={canonical}>
<meta property="og:site_name" content="Sabdia Constructions">
<meta property="og:locale" content="en_AU">
<meta property="og:image" content={ogImageAbs}>
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={ogT}>
<meta name="twitter:description" content={ogD}>
<meta name="twitter:image" content={ogImageAbs}>
{gaId && <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>}
{gaId && <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)};gtag('js',new Date());gtag('config','${gaId}');`}></script>}
<link rel="preconnect" href="https://fvczsjcrvwzqtcbforgo.supabase.co" crossorigin>
<link rel="preload" as="font" type="font/woff2" href="/fonts/jost-var.woff2" crossorigin>
<link rel="preload" as="font" type="font/woff2" href="/fonts/cormorant-garamond-var.woff2" crossorigin>
<link rel="preload" as="font" type="font/woff2" href="/fonts/eb-garamond-var-italic.woff2" crossorigin>
{preloadImage && <link rel="preload" as="image" href={preloadImage} imagesrcset={preloadImageSet} imagesizes={preloadImageSet ? (preloadImageSizes ?? '100vw') : undefined} media={preloadImageMedia}>}
<link rel="stylesheet" href={withV('/css/style.css')}>
<ClientRouter />
<slot name="head" />
</head>
<body>

<a href="#main" class="skip-link">Skip to content</a>

<Nav lightNav={lightNav} />

<main id="main">
<slot />
</main>

<Footer />
<script src={withV('/js/main.js')} is:inline></script>
</body>
</html>
