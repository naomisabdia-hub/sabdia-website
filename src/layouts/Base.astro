---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  preloadImage?: string;
  preloadImageSet?: string;
  preloadImageSizes?: string;
}

const { title, description, ogTitle, ogDescription, ogImage, preloadImage, preloadImageSet, preloadImageSizes } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="theme-color" content="#F7F3EB">
<title>{title}</title>
<meta name="description" content={description}>
<link rel="canonical" href={canonical}>
<script is:inline>document.documentElement.classList.add('js');</script>
{ogTitle && <meta property="og:title" content={ogTitle}>}
{(ogDescription || ogTitle) && <meta property="og:description" content={ogDescription ?? description}>}
{ogTitle && <meta property="og:type" content="website">}
{ogImage && <meta property="og:image" content={ogImage}>}
{ogImage && <meta name="twitter:card" content="summary_large_image">}
<link rel="preload" as="font" type="font/woff2" href="/fonts/jost-var.woff2" crossorigin>
<link rel="preload" as="font" type="font/woff2" href="/fonts/cormorant-garamond-var.woff2" crossorigin>
<link rel="preload" as="font" type="font/woff2" href="/fonts/eb-garamond-var-italic.woff2" crossorigin>
{preloadImage && <link rel="preload" as="image" href={preloadImage} imagesrcset={preloadImageSet} imagesizes={preloadImageSet ? (preloadImageSizes ?? '100vw') : undefined}>}
<link rel="stylesheet" href="/css/style.css">
<slot name="head" />
</head>
<body>

<a href="#main" class="skip-link">Skip to content</a>

<Nav />

<main id="main">
<slot />
</main>

<Footer />
<script src="/js/main.js" is:inline></script>
</body>
</html>
