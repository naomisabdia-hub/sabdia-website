# Supabase (Project Settings → API)
# Without these the site renders from bundled seed data and forms cannot be stored.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Same URL + anon key, exposed to the browser for the /admin portal.
# (The anon key is safe to expose — Row Level Security enforces access.)
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: email a copy of each enquiry via https://resend.com
RESEND_API_KEY=
CONTACT_EMAIL=
# Optional verified sender, e.g. "Sabdia Website <noreply@sabdiaconstructions.com.au>"
CONTACT_FROM=

# Clerk (optional) — when set, admin sign-in switches from Supabase auth
# to Clerk. See CLERK-SETUP.md for the full activation steps.
PUBLIC_CLERK_PUBLISHABLE_KEY=
